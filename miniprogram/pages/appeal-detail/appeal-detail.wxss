/* pages/appeal-detail/appeal-detail.wxss */

page {
  background: linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%);
  min-height: 100vh;
  height: 100%;
  margin: 0;
  padding: 0;
}

/* 页面容器 */
.container {
  padding: 0;
  box-sizing: border-box;
  animation: fadeIn 0.4s ease forwards;
  min-height: 100vh;
  height: 100%;
  display: flex;
  flex-direction: column;
  width: 100%;
  max-width: 100%;
  margin: 0;
}



/* 顶部导航栏 */
.nav-bar {
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.95);
  border-radius: 32rpx;
  padding: 30rpx;
  margin: 20rpx 20rpx 20rpx;
  box-shadow: 0 16rpx 50rpx rgba(0, 0, 0, 0.1), 0 8rpx 24rpx rgba(0, 0, 0, 0.06);
  backdrop-filter: blur(30rpx);
  border: 1rpx solid rgba(255, 255, 255, 0.8);
  transition: all 0.3s ease;
  animation: slideUp 0.6s cubic-bezier(0.34, 1.56, 0.64, 1) forwards;
}

.nav-title {
  flex: 1;
  text-align: center;
}

.title {
  font-size: 36rpx;
  font-weight: 800;
  color: #333;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  letter-spacing: -1rpx;
  text-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.08);
}

.nav-right {
  width: 80rpx;
}

/* 加载状态 */
.loading-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 100%;
  padding: 0 40rpx;
  animation: slideUp 0.6s cubic-bezier(0.34, 1.56, 0.64, 1) 0.2s forwards;
  opacity: 0;
}

.loading-spinner {
  width: 96rpx;
  height: 96rpx;
  border: 10rpx solid rgba(102, 126, 234, 0.2);
  border-top: 10rpx solid #667eea;
  border-radius: 50%;
  animation: spin 1s linear infinite;
  margin-bottom: 36rpx;
  box-shadow: 0 6rpx 24rpx rgba(102, 126, 234, 0.3);
}

.loading-text {
  font-size: 32rpx;
  color: #666;
  text-align: center;
  line-height: 1.5;
  font-weight: 500;
}

@keyframes spin {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}

/* 详情卡片 */
.detail-card {
  background: rgba(255, 255, 255, 0.95);
  border-radius: 32rpx;
  padding: 0;
  box-shadow: 0 16rpx 50rpx rgba(0, 0, 0, 0.1), 0 8rpx 24rpx rgba(0, 0, 0, 0.06);
  backdrop-filter: blur(30rpx);
  border: 1rpx solid rgba(255, 255, 255, 0.8);
  animation: slideUp 0.6s cubic-bezier(0.34, 1.56, 0.64, 1) 0.4s forwards;
  opacity: 0;
  overflow: hidden;
  flex: 1;
  margin: 0 20rpx 20rpx;
  display: flex;
  flex-direction: column;
  width: calc(100% - 40rpx);
}

/* 卡片内容 */
.card-content {
  padding: 48rpx;
  flex: 1;
  display: flex;
  flex-direction: column;
  overflow-y: auto;
  max-height: calc(100vh - 300rpx);
  -webkit-overflow-scrolling: touch;
}

.card-content::-webkit-scrollbar {
  display: none;
}

/* 状态徽章 */
.status-badge {
  display: inline-block;
  padding: 16rpx 36rpx;
  border-radius: 32rpx;
  font-size: 28rpx;
  font-weight: 600;
  text-align: center;
  min-width: 160rpx;
  box-shadow: 0 6rpx 20rpx rgba(0, 0, 0, 0.2);
  transition: all 0.3s ease;
  backdrop-filter: blur(10rpx);
  margin-bottom: 56rpx;
}

.status-badge.large {
  padding: 20rpx 48rpx;
  font-size: 36rpx;
  min-width: 240rpx;
  border-radius: 40rpx;
}

.status-pending {
  color: #ff9f0a;
  background-color: rgba(255, 159, 10, 0.1);
}

.status-success {
  color: #07c160;
  background-color: rgba(7, 193, 96, 0.1);
}

.status-failed {
  color: #ff2b2b;
  background-color: rgba(255, 43, 43, 0.1);
}

/* 信息项 */
.info-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx 0;
  border-bottom: 1rpx solid rgba(102, 126, 234, 0.1);
}

.info-item:last-child {
  border-bottom: none;
}

.info-label {
  font-size: 32rpx;
  color: #666;
  font-weight: 500;
}

.info-value {
  font-size: 32rpx;
  color: #333;
  font-weight: 600;
}

/* 申诉理由部分 */
.appeal-reason-section {
  margin-top: 56rpx;
  padding: 40rpx;
  background: rgba(102, 126, 234, 0.05);
  border-radius: 24rpx;
  border-left: 4rpx solid #667eea;
}

.section-title {
  font-size: 36rpx;
  font-weight: 800;
  color: #333;
  margin-bottom: 24rpx;
  display: block;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  letter-spacing: -1rpx;
  text-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.08);
}

.appeal-reason-content {
  font-size: 32rpx;
  color: #333;
  line-height: 1.6;
  white-space: pre-wrap;
  word-break: break-word;
}

/* 证明材料部分 */
.evidence-section {
  margin-top: 56rpx;
}

.evidence-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 24rpx;
  margin-top: 24rpx;
}

.evidence-item {
  width: calc(33.333% - 16rpx);
  aspect-ratio: 1;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.1);
  transition: all 0.3s ease;
}

.evidence-item:active {
  transform: scale(0.95);
}

.evidence-image {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

/* 审核结果部分 */
.audit-result-section {
  margin-top: 56rpx;
  padding: 40rpx;
  background: rgba(102, 126, 234, 0.05);
  border-radius: 24rpx;
  border-left: 4rpx solid #667eea;
}

.audit-result-content {
  font-size: 32rpx;
  color: #333;
  line-height: 1.6;
  white-space: pre-wrap;
  word-break: break-word;
}

/* 关联跑步记录部分 */
.running-record-section {
  margin-top: 56rpx;
}

.running-record-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 40rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.08);
  transition: all 0.3s ease;
  cursor: pointer;
  border: 1rpx solid rgba(102, 126, 234, 0.1);
}

.running-record-card:active {
  transform: translateY(-2rpx);
  box-shadow: 0 12rpx 32rpx rgba(102, 126, 234, 0.15);
}

.record-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.record-date {
  font-size: 30rpx;
  font-weight: 500;
  color: #333;
}

.record-status-badge {
  padding: 4px 8px;
  border-radius: 12px;
  font-size: 12px;
  font-weight: 500;
}

/* 记录数据 */
.record-data {
  display: flex;
  justify-content: space-around;
  margin-bottom: 24rpx;
}

.data-item {
  text-align: center;
  flex: 1;
  padding: 16rpx;
  background: rgba(102, 126, 234, 0.05);
  border-radius: 16rpx;
  margin: 0 8rpx;
}

.data-value {
  font-size: 28rpx;
  font-weight: 700;
  color: #667eea;
  display: block;
  margin-bottom: 8rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.data-label {
  font-size: 24rpx;
  color: #666;
}

.view-detail-text {
  font-size: 26rpx;
  color: #667eea;
  font-weight: 600;
  text-align: right;
  display: block;
  margin-top: 16rpx;
  transition: all 0.3s ease;
}

.view-detail-text:active {
  color: #764ba2;
}

/* 动画效果 */
@keyframes fadeIn {
  from {
    opacity: 0;
    transform: translateY(20rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

@keyframes slideUp {
  from {
    opacity: 0;
    transform: translateY(40rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

/* 响应式设计 */
@media (max-width: 375px) {
  .container {
    padding: 0;
  }
  
  .nav-bar,
  .detail-card {
    padding: 32rpx;
    margin-bottom: 0;
  }
  
  .title,
  .section-title {
    font-size: 32rpx;
  }
  
  .status-badge.large {
    padding: 12rpx 32rpx;
    font-size: 28rpx;
    min-width: 160rpx;
  }
  
  .info-item {
    padding: 20rpx 0;
  }
  
  .info-label,
  .info-value {
    font-size: 26rpx;
  }
  
  .appeal-reason-content,
  .audit-result-content {
    font-size: 26rpx;
  }
  
  .evidence-item {
    width: calc(50% - 10rpx);
  }
  
  .running-record-card {
    padding: 24rpx;
  }
  
  .record-date {
    font-size: 26rpx;
  }
  
  .data-value {
    font-size: 26rpx;
  }
  
  .data-label {
    font-size: 22rpx;
  }
}
