<!--pages/register/register.wxml-->
<view class="top-box">
  <view>注册账号</view>
  <view class="next-text">星轨Runner</view>
</view>
<!-- 注册 -->
<view class="center-box">
  <view class="input-box">
    <view class="wei-input">
      <icon type="waiting" color="#44ADFB" size="16"></icon>
      <input class="input" bindinput="onPhoneInput" placeholder="请输入手机号" maxlength="11" type="number"/>
    </view>
    <view class="wei-input">
      <icon type="waiting" color="#44ADFB" size="16"></icon>
      <input class="input" bindinput="onCodeInput" placeholder="请输入6位验证码" maxlength="6" type="number"/>
      <text class="input-code" bindtap="getCode">{{codeText}}</text>
    </view>
    <view class="wei-input">
      <icon type="success" color="#44ADFB" size="16"></icon>
      <input class="input" bindinput="onPasswordInput" placeholder="请输入密码" password="{{true}}"/>
    </view>
    <view class="wei-input">
      <icon type="success" color="#44ADFB" size="16"></icon>
      <input class="input" bindinput="onConfirmPasswordInput" placeholder="请确认密码" password="{{true}}"/>
    </view>
  </view>
  <view class="sumbit-btn">
    <button class="button" 
    style="background-color: #33ccff;font-size: 30rpx;" 
    type="primary" bindtap="register">立即注册</button>
  </view>
  <view class="login-link" bindtap="toLogin">
    <text>已有账号，去登录→</text>
  </view>
</view>
