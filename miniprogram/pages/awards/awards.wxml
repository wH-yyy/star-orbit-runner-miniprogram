<!--pages/awards/awards.wxml-->
<view class="container">
  <text class="title">我的奖项</text>
  
  <!-- 奖项卡片 -->
  <view class="award-card">
    <view class="award-header">
      <text class="award-title">当前奖项</text>
      <view class="award-badge">{{userAward}}</view>
    </view>
    
    <!-- 奖项说明 -->
    <view class="award-description">
      <text class="description-text">根据您的参与次数和活动总次数，您当前获得的奖项是</text>
      <text class="award-level">{{userAward}}</text>
    </view>
    
    <!-- 统计信息 -->
    <view class="stats-container">
      <!-- 总活动次数 -->
      <view class="stat-item">
        <view class="stat-number">{{totalActivities}}</view>
        <view class="stat-label">总活动次数</view>
      </view>
      
      <!-- 参与次数 -->
      <view class="stat-item">
        <view class="stat-number">{{userParticipations}}</view>
        <view class="stat-label">参与次数</view>
      </view>
      
      <!-- 参与比例 -->
      <view class="stat-item">
        <view class="stat-number">{{participationRate}}%</view>
        <view class="stat-label">参与比例</view>
      </view>
    </view>
    
    <!-- 奖项说明文字 -->
    <view class="award-info">
      <text class="info-title">奖项说明</text>
      <view class="info-list">
        <view class="info-item">
          <text class="info-level">一等奖：</text>
          <text class="info-desc">参与率 {{symbols.greaterEqual}} 90%</text>
        </view>
        <view class="info-item">
          <text class="info-level">二等奖：</text>
          <text class="info-desc">参与率 {{symbols.greaterEqual}} 70%</text>
        </view>
        <view class="info-item">
          <text class="info-level">三等奖：</text>
          <text class="info-desc">参与率 {{symbols.greaterEqual}} 50%</text>
        </view>
        <view class="info-item">
          <text class="info-level">参与奖：</text>
          <text class="info-desc">参与率 {{symbols.lessThan}} 50%</text>
        </view>
      </view>
    </view>
  </view>
  
  <!-- 提示信息 -->
  <view class="tips">
    <text class="tips-text">* 奖项会根据活动次数和您的参与情况实时更新</text>
  </view>
</view>