<!--pages/awards/awards.wxml-->
<view class="container">
  <!-- 页面标题 -->
  <view class="header">
    <text class="title">根据您的跑步参与情况</text>
  </view>
  
  <!-- 主奖项卡片 -->
  <view class="main-card">
    <view class="award-badge">
      <text class="award-label">当前奖项</text>
      <text class="award-level">{{userAwardList[userAwardIndex]}}</text>
    </view>
    
    <!-- 进度展示 -->
    <view class="progress-section">
      <view class="progress-info">
        <text class="progress-text">参与进度</text>
        <text class="progress-percent">{{participationRate}}%</text>
      </view>
      <view class="progress-bar">
        <view class="progress-fill" style="width: {{participationRate}}%"></view>
      </view>
    </view>
    
    <!-- 统计数据 -->
    <view class="stats-grid">
      <view class="stat-item">
        <text class="stat-number">{{userParticipations}}</text>
        <text class="stat-label">参与次数</text>
      </view>
      <view class="stat-divider"></view>
      <view class="stat-item">
        <text class="stat-number">{{totalActivities}}</text>
        <text class="stat-label">总活动次数</text>
      </view>
    </view>
  </view>
  
  <!-- 奖项规则说明 -->
  <view class="rules-card">
    <text class="rules-title">奖项规则</text>
    <view class="rules-list">
      <view class="rule-item">
        <view class="rule-badge rule-gold">一等奖</view>
        <text class="rule-desc">参与率 ≥ 85%</text>
      </view>
      <view class="rule-item">
        <view class="rule-badge rule-silver">二等奖</view>
        <text class="rule-desc">参与率 ≥ 75%</text>
      </view>
      <view class="rule-item">
        <view class="rule-badge rule-bronze">三等奖</view>
        <text class="rule-desc">参与率 ≥ 60%</text>
      </view>
      <view class="rule-item">
        <view class="rule-badge rule-participation">运动奖</view>
        <text class="rule-desc">参与率＜ 60%</text>
      </view>
    </view>
  </view>
  
  <!-- 底部提示 -->
  <view class="footer-tip">
    <text class="tip-text">本页面奖项不代表最终结果</text>
  </view>
</view>