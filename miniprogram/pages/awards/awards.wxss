/* pages/awards/awards.wxss */

/* 基础容器 - 响应式设计 */
.container {
  min-height: 100vh;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  padding: 40rpx 30rpx;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  align-items: center;
}

/* 页面头部 */
.header {
  text-align: center;
  margin-bottom: 40rpx;
  width: 100%;
}

.title {
  font-size: 40rpx;
  font-weight: 600;
  color: #ffffff;
  letter-spacing: 2rpx;
  margin-bottom: 12rpx;
  text-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.2);
}

/* 主奖项卡片 */
.main-card {
  background: rgba(255, 255, 255, 0.95);
  border-radius: 32rpx;
  padding: 40rpx;
  box-shadow: 0 20rpx 60rpx rgba(0, 0, 0, 0.15);
  backdrop-filter: blur(20rpx);
  border: 1rpx solid rgba(255, 255, 255, 0.3);
  width: 100%;
  max-width: 600rpx;
  margin-bottom: 30rpx;
  animation: slideUp 0.8s cubic-bezier(0.34, 1.56, 0.64, 1) forwards;
}

/* 奖项徽章 */
.award-badge {
  text-align: center;
  margin-bottom: 40rpx;
  padding: 30rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 24rpx;
  box-shadow: 0 12rpx 36rpx rgba(102, 126, 234, 0.3);
}

.award-level {
  display: block;
  font-size: 64rpx;
  font-weight: 800;
  color: #ffffff;
  margin-bottom: 8rpx;
  text-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.2);
  animation: glow 2s ease-in-out infinite alternate;
}

.award-label {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.9);
  letter-spacing: 2rpx;
}

/* 进度展示 */
.progress-section {
  margin-bottom: 40rpx;
}

.progress-info {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.progress-text {
  font-size: 28rpx;
  color: #333333;
  font-weight: 600;
}

.progress-percent {
  font-size: 36rpx;
  font-weight: 700;
  color: #667eea;
}

.progress-bar {
  height: 12rpx;
  background: rgba(102, 126, 234, 0.1);
  border-radius: 6rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #667eea 0%, #764ba2 100%);
  border-radius: 6rpx;
  transition: width 1s ease-in-out;
  box-shadow: 0 2rpx 8rpx rgba(102, 126, 234, 0.3);
}

/* 统计数据网格 */
.stats-grid {
  display: flex;
  align-items: center;
  justify-content: space-around;
  background: rgba(102, 126, 234, 0.05);
  border-radius: 20rpx;
  padding: 24rpx;
}

.stat-item {
  text-align: center;
  flex: 1;
}

.stat-number {
  display: block;
  font-size: 48rpx;
  font-weight: 700;
  color: #667eea;
  margin-bottom: 4rpx;
  line-height: 1;
}

.stat-label {
  font-size: 24rpx;
  color: #666666;
}

.stat-divider {
  width: 2rpx;
  height: 60rpx;
  background: rgba(102, 126, 234, 0.2);
  margin: 0 20rpx;
}

/* 规则卡片 */
.rules-card {
  background: rgba(255, 255, 255, 0.9);
  border-radius: 24rpx;
  padding: 32rpx;
  box-shadow: 0 12rpx 36rpx rgba(0, 0, 0, 0.08);
  width: 100%;
  max-width: 600rpx;
  margin-bottom: 30rpx;
}

.rules-title {
  display: block;
  font-size: 32rpx;
  font-weight: 700;
  color: #333333;
  margin-bottom: 24rpx;
  text-align: center;
}

.rules-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.rule-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx;
  background: rgba(255, 255, 255, 0.8);
  border-radius: 16rpx;
  border: 1rpx solid rgba(102, 126, 234, 0.1);
}

.rule-badge {
  padding: 12rpx 20rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
  font-weight: 600;
  color: #ffffff;
  min-width: 120rpx;
  text-align: center;
}

.rule-gold {
  background: linear-gradient(135deg, #FFD700 0%, #FFA500 100%);
  box-shadow: 0 4rpx 12rpx rgba(255, 215, 0, 0.3);
}

.rule-silver {
  background: linear-gradient(135deg, #F0F2F4 0%, #C0C0C0 100%);
  box-shadow: 0 4rpx 12rpx rgba(192, 192, 192, 0.3);
}

.rule-bronze {
  background: linear-gradient(135deg, #CD7F32 0%, #8B4513 100%);
  box-shadow: 0 4rpx 12rpx rgba(205, 127, 50, 0.3);
}

.rule-participation {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  box-shadow: 0 4rpx 12rpx rgba(102, 126, 234, 0.3);
}

.rule-desc {
  font-size: 26rpx;
  color: #666666;
  font-weight: 500;
}

/* 底部提示 */
.footer-tip {
  text-align: center;
  width: 100%;
}

.tip-text {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.7);
  letter-spacing: 1rpx;
}

/* 动画效果 */
@keyframes slideUp {
  from {
    opacity: 0;
    transform: translateY(40rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

@keyframes glow {
  from {
    text-shadow: 0 0 20rpx rgba(255, 255, 255, 0.5);
  }
  to {
    text-shadow: 0 0 30rpx rgba(255, 255, 255, 0.8);
  }
}

/* 响应式适配 */
@media screen and (max-width: 375px) {
  .container {
    padding: 30rpx 20rpx;
  }
  
  .main-card,
  .rules-card {
    padding: 30rpx;
    border-radius: 24rpx;
  }
  
  .award-level {
    font-size: 56rpx;
  }
  
  .stat-number {
    font-size: 40rpx;
  }
  
  .rule-item {
    flex-direction: column;
    gap: 16rpx;
    text-align: center;
  }
}

@media screen and (min-width: 600px) {
  .container {
    padding: 60rpx 40rpx;
  }
  
  .main-card,
  .rules-card {
    max-width: 700rpx;
  }
  
  .award-level {
    font-size: 72rpx;
  }
  
  .stats-grid {
    padding: 32rpx;
  }
}

/* 安全区域适配 */
.safe-area {
  padding-bottom: env(safe-area-inset-bottom);
}

/* 暗色模式适配 */
@media (prefers-color-scheme: dark) {
  .main-card,
  .rules-card {
    background: rgba(30, 30, 30, 0.9);
    color: #ffffff;
  }
  
  .progress-text,
  .stat-label,
  .rules-title,
  .rule-desc {
    color: #ffffff;
  }
  
  .stat-number {
    color: #667eea;
  }
}