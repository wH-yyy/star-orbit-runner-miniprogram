/* pages/awards/awards.wxss */

/* 基础容器 - 响应式设计 */
.container {
  min-height: 100vh;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  padding: 5% 4%;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: flex-start;
  padding-bottom: calc(5% + env(safe-area-inset-bottom));
}

/* 页面头部 */
.header {
  text-align: center;
  margin-bottom: 5%;
  width: 100%;
  padding: 0 4%;
}

.title {
  font-size: 1.4em;
  font-weight: 500;
  color: #ffffff;
  letter-spacing: 0.05em;
  margin-bottom: 0.4em;
  text-shadow: 0 0.1em 0.3em rgba(0, 0, 0, 0.2);
  line-height: 1.4;
}

/* 主奖项卡片 */
.main-card {
  background: rgba(255, 255, 255, 0.95);
  border-radius: 1.5em;
  padding: 8%;
  box-shadow: 0 1em 3em rgba(0, 0, 0, 0.15);
  backdrop-filter: blur(1em);
  border: 0.05em solid rgba(255, 255, 255, 0.3);
  width: 92%;
  max-width: 28em;
  margin-bottom: 4%;
  animation: slideUp 0.8s cubic-bezier(0.34, 1.56, 0.64, 1) forwards;
}

/* 奖项徽章 */
.award-badge {
  text-align: center;
  margin-bottom: 8%;
  padding: 6%;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 1.2em;
  box-shadow: 0 0.6em 1.8em rgba(102, 126, 234, 0.3);
}

.award-level {
  display: block;
  font-size: 1.8em;
  font-weight: 600;
  color: #ffffff;
  margin-bottom: 0.2em;
  text-shadow: 0 0.1em 0.3em rgba(0, 0, 0, 0.2);
  animation: glow 2s ease-in-out infinite alternate;
  line-height: 1.3;
}

.award-label {
  font-size: 0.9em;
  color: rgba(255, 255, 255, 0.85);
  letter-spacing: 0.08em;
  line-height: 1.4;
}

/* 进度展示 */
.progress-section {
  margin-bottom: 8%;
}

.progress-info {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 4%;
}

.progress-text {
  font-size: 0.9em;
  color: #555555;
  font-weight: 500;
  line-height: 1.4;
}

.progress-percent {
  font-size: 1.1em;
  font-weight: 600;
  color: #667eea;
  line-height: 1.2;
}

.progress-bar {
  height: 0.6em;
  background: rgba(102, 126, 234, 0.1);
  border-radius: 0.3em;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #667eea 0%, #764ba2 100%);
  border-radius: 0.3em;
  transition: width 1s ease-in-out;
  box-shadow: 0 0.1em 0.4em rgba(102, 126, 234, 0.3);
}

/* 统计数据网格 */
.stats-grid {
  display: flex;
  align-items: center;
  justify-content: space-around;
  background: rgba(102, 126, 234, 0.05);
  border-radius: 1em;
  padding: 5%;
}

.stat-item {
  text-align: center;
  flex: 1;
  min-width: 0;
}

.stat-number {
  display: block;
  font-size: 1.4em;
  font-weight: 600;
  color: #667eea;
  margin-bottom: 0.15em;
  line-height: 1.2;
}

.stat-label {
  font-size: 0.85em;
  color: #777777;
  line-height: 1.3;
}

.stat-divider {
  width: 0.1em;
  height: 3em;
  background: rgba(102, 126, 234, 0.2);
  margin: 0 4%;
  flex-shrink: 0;
}

/* 规则卡片 */
.rules-card {
  background: rgba(255, 255, 255, 0.9);
  border-radius: 1.2em;
  padding: 6%;
  box-shadow: 0 0.6em 1.8em rgba(0, 0, 0, 0.08);
  width: 92%;
  max-width: 28em;
  margin-bottom: 4%;
}

.rules-title {
  display: block;
  font-size: 1.1em;
  font-weight: 600;
  color: #444444;
  margin-bottom: 4%;
  text-align: center;
  line-height: 1.4;
}

.rules-list {
  display: flex;
  flex-direction: column;
  gap: 4%;
}

.rule-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 4%;
  background: rgba(255, 255, 255, 0.8);
  border-radius: 0.8em;
  border: 0.05em solid rgba(102, 126, 234, 0.1);
  flex-wrap: nowrap;
  min-height: 3em;
}

.rule-badge {
  padding: 0.5em 0.8em;
  border-radius: 1em;
  font-size: 0.85em;
  font-weight: 500;
  color: #ffffff;
  min-width: 4.5em;
  text-align: center;
  line-height: 1.3;
  flex-shrink: 0;
  white-space: nowrap;
}

.rule-gold {
  background: linear-gradient(135deg, #FFD700 0%, #FFA500 100%);
}

.rule-silver {
  background: linear-gradient(135deg, #F0F2F4 0%, #C0C0C0 100%);
}

.rule-bronze {
  background: linear-gradient(135deg, #CD7F32 0%, #8B4513 100%);
}

.rule-participation {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
}

.rule-desc {
  font-size: 0.85em;
  color: #666666;
  font-weight: 400;
  line-height: 1.4;
  flex: 1;
  text-align: right;
  white-space: nowrap;
}

/* 底部提示 */
.footer-tip {
  text-align: center;
  width: 100%;
  padding: 0 4%;
}

.tip-text {
  font-size: 0.8em;
  color: rgba(255, 255, 255, 0.6);
  letter-spacing: 0.03em;
  line-height: 1.5;
}

/* 动画效果 */
@keyframes slideUp {
  from {
    opacity: 0;
    transform: translateY(2em);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

@keyframes glow {
  from {
    text-shadow: 0 0 1em rgba(255, 255, 255, 0.5);
  }
  to {
    text-shadow: 0 0 1.5em rgba(255, 255, 255, 0.8);
  }
}

/* 响应式适配 */
@media screen and (max-width: 375px) {
  .container {
    padding: 4% 3%;
  }
  
  .main-card,
  .rules-card {
    padding: 6%;
    border-radius: 1.2em;
    width: 94%;
  }
  
  .award-level {
    font-size: 1.6em;
  }
  
  .stat-number {
    font-size: 1.2em;
  }
  
  .rule-item {
    flex-direction: row;
    gap: 4%;
    text-align: left;
    flex-wrap: nowrap;
    align-items: center;
  }
  
  .rule-badge {
    min-width: 4em;
    flex-shrink: 0;
    font-size: 0.8em;
    padding: 0.4em 0.7em;
  }
  
  .rule-desc {
    flex: 1;
    text-align: right;
    font-size: 0.8em;
  }
}

/* 超小屏幕适配 */
@media screen and (max-width: 320px) {
  .rule-item {
    gap: 3%;
    padding: 3%;
  }
  
  .rule-badge {
    min-width: 3.5em;
    font-size: 0.75em;
    padding: 0.35em 0.6em;
  }
  
  .rule-desc {
    font-size: 0.75em;
  }
}

@media screen and (min-width: 600px) {
  .container {
    padding: 8% 6%;
  }
  
  .main-card,
  .rules-card {
    max-width: 32em;
    width: 88%;
  }
  
  .award-level {
    font-size: 2em;
  }
  
  .stats-grid {
    padding: 6%;
  }
  
  .rules-list {
    gap: 5%;
  }
}

/* 安全区域适配 */
.container {
  padding-bottom: env(safe-area-inset-bottom);
}

/* 暗色模式适配 */
@media (prefers-color-scheme: dark) {
  .main-card,
  .rules-card {
    background: rgba(30, 30, 30, 0.9);
    color: #ffffff;
  }
  
  .progress-text,
  .stat-label,
  .rules-title,
  .rule-desc {
    color: #ffffff;
  }
  
  .stat-number {
    color: #667eea;
  }
}