/* pages/awards/awards.wxss */

/* 基础容器 - 响应式设计 */
.container {
  min-height: 100vh;
  background: linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%);
  background-attachment: fixed;
  padding: 40rpx 30rpx;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: flex-start;
  padding-bottom: calc(40rpx + env(safe-area-inset-bottom));
}

/* 页面头部 */
.header {
  text-align: center;
  margin-bottom: 40rpx;
  width: 100%;
  padding: 0 30rpx;
}

.title {
  font-size: 44rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 12rpx;
  background: linear-gradient(135deg, #5783c5 0%, #4276c4 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  line-height: 1.4;
}

/* 主奖项卡片 */
.main-card {
  background: rgba(255, 255, 255, 0.95);
  border-radius: 32rpx;
  padding: 40rpx;
  box-shadow: 0 16rpx 50rpx rgba(0, 0, 0, 0.1), 0 8rpx 24rpx rgba(0, 0, 0, 0.06);
  backdrop-filter: blur(30rpx);
  border: 1rpx solid rgba(255, 255, 255, 0.8);
  width: 600rpx;
  max-width: 600rpx;
  margin-bottom: 24rpx;
  animation: slideUp 0.6s cubic-bezier(0.34, 1.56, 0.64, 1) forwards;
  transition: all 0.3s ease;
}

/* 奖项徽章 */
.award-badge {
  text-align: center;
  margin-bottom: 40rpx;
  padding: 32rpx;
  background: linear-gradient(135deg, #6690ea 0%, #4b68a2 100%);
  border-radius: 24rpx;
  box-shadow: 0 8rpx 28rpx rgba(102, 126, 234, 0.3);
}

.award-level {
  display: block;
  font-size: 48rpx;
  font-weight: 600;
  color: #ffffff;
  margin-bottom: 8rpx;
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.2);
  line-height: 1.2;
}

.award-label {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.9);
  line-height: 1.3;
}

/* 进度展示 */
.progress-section {
  margin-bottom: 40rpx;
}

.progress-info {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.progress-text {
  font-size: 26rpx;
  color: #666666;
  font-weight: 500;
  line-height: 1.3;
}

.progress-percent {
  font-size: 30rpx;
  font-weight: 600;
  color: #758ec2;
  line-height: 1.1;
}

.progress-bar {
  height: 8rpx;
  background: rgba(102, 126, 234, 0.1);
  border-radius: 4rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #6690ea 0%, #436ac5 100%);
  border-radius: 4rpx;
  transition: width 1s ease-in-out;
  box-shadow: 0 2rpx 8rpx rgba(102, 126, 234, 0.3);
}

/* 统计数据网格 */
.stats-grid {
  display: flex;
  align-items: center;
  justify-content: space-around;
  background: rgba(102, 126, 234, 0.05);
  border-radius: 24rpx;
  padding: 28rpx;
}

.stat-item {
  text-align: center;
  flex: 1;
  min-width: 0;
}

.stat-number {
  display: block;
  font-size: 40rpx;
  font-weight: 600;
  color: #667eea;
  margin-bottom: 4rpx;
  line-height: 1.1;
}

.stat-label {
  font-size: 24rpx;
  color: #666666;
  line-height: 1.2;
}

.stat-divider {
  width: 2rpx;
  height: 64rpx;
  background: rgba(102, 126, 234, 0.2);
  margin: 0 24rpx;
  flex-shrink: 0;
}

/* 规则卡片 */
.rules-card {
  background: rgba(255, 255, 255, 0.95);
  border-radius: 32rpx;
  padding: 32rpx;
  box-shadow: 0 16rpx 50rpx rgba(0, 0, 0, 0.1), 0 8rpx 24rpx rgba(0, 0, 0, 0.06);
  backdrop-filter: blur(30rpx);
  border: 1rpx solid rgba(255, 255, 255, 0.8);
  width: 600rpx;
  max-width: 600rpx;
  margin-bottom: 24rpx;
  animation: slideUp 0.6s cubic-bezier(0.34, 1.56, 0.64, 1) forwards;
  transition: all 0.3s ease;
}

.rules-title {
  display: block;
  font-size: 30rpx;
  font-weight: 700;
  color: #333333;
  margin-bottom: 24rpx;
  text-align: center;
  background: linear-gradient(135deg, #5783c5 0%, #4276c4 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  line-height: 1.3;
}

.rules-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.rule-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx;
  background: rgba(255, 255, 255, 0.9);
  border-radius: 20rpx;
  border: 1rpx solid rgba(102, 126, 234, 0.1);
  flex-wrap: nowrap;
  min-height: 72rpx;
}

.rule-badge {
  padding: 12rpx 20rpx;
  border-radius: 24rpx;
  font-size: 24rpx;
  font-weight: 500;
  color: #ffffff;
  min-width: 120rpx;
  text-align: center;
  line-height: 1.2;
  flex-shrink: 0;
  white-space: nowrap;
}

.rule-gold {
  background: linear-gradient(135deg, #FFD700 0%, #FFA500 100%);
}

.rule-silver {
  background: linear-gradient(135deg, #d5d6d7 0%, #b7b7b7 100%);
}

.rule-bronze {
  background: linear-gradient(135deg, #d29251 0%, #a66639 100%);
}

.rule-participation {
  background: linear-gradient(135deg, #6690ea 0%, #4b68a2 100%);
}

.rule-desc {
  font-size: 24rpx;
  color: #666666;
  font-weight: 400;
  line-height: 1.3;
  flex: 1;
  text-align: right;
  white-space: nowrap;
}

/* 底部提示 */
.footer-tip {
  text-align: center;
  width: 100%;
  padding: 0 30rpx;
}

.tip-text {
  font-size: 24rpx;
  color: #666666;
  line-height: 1.5;
}

/* 动画效果 */
@keyframes slideUp {
  from {
    opacity: 0;
    transform: translateY(64rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

@keyframes glow {
  from {
    text-shadow: 0 0 32rpx rgba(255, 255, 255, 0.5);
  }
  to {
    text-shadow: 0 0 48rpx rgba(255, 255, 255, 0.8);
  }
}

/* 响应式适配 */
@media screen and (max-width: 375px) {
  .container {
    padding: 24rpx 16rpx;
  }
  
  .main-card,
  .rules-card {
    padding: 32rpx;
    border-radius: 24rpx;
    width: 560rpx;
  }
  
  .award-level {
    font-size: 40rpx;
  }
  
  .stat-number {
    font-size: 32rpx;
  }
  
  .rule-item {
    flex-direction: row;
    gap: 20rpx;
    text-align: left;
    flex-wrap: nowrap;
    align-items: center;
  }
  
  .rule-badge {
    min-width: 100rpx;
    flex-shrink: 0;
    font-size: 22rpx;
    padding: 8rpx 16rpx;
  }
  
  .rule-desc {
    flex: 1;
    text-align: right;
    font-size: 22rpx;
  }
}

/* 超小屏幕适配 */
@media screen and (max-width: 320px) {
  .rule-item {
    gap: 16rpx;
    padding: 16rpx;
  }
  
  .rule-badge {
    min-width: 90rpx;
    font-size: 20rpx;
    padding: 6rpx 12rpx;
  }
  
  .rule-desc {
    font-size: 20rpx;
  }
}

@media screen and (min-width: 600px) {
  .container {
    padding: 48rpx 36rpx;
  }
  
  .main-card,
  .rules-card {
    max-width: 640rpx;
    width: 640rpx;
  }
  
  .award-level {
    font-size: 56rpx;
  }
  
  .stats-grid {
    padding: 32rpx;
  }
  
  .rules-list {
    gap: 24rpx;
  }
}

/* 安全区域适配 */
.container {
  padding-bottom: env(safe-area-inset-bottom);
}