/* pages/awards/awards.wxss */
.container {
  min-height: 100vh;
  background: linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%);
  padding: 40rpx 30rpx;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.title {
  font-size: 44rpx;
  font-weight: 700;
  color: #333333;
  letter-spacing: 2rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  margin-bottom: 40rpx;
  text-align: center;
  width: 100%;
  animation: fadeIn 0.6s ease forwards;
}

/* 奖项卡片 */
.award-card {
  background: rgba(255, 255, 255, 0.95);
  border-radius: 32rpx;
  padding: 40rpx;
  box-shadow: 0 20rpx 60rpx rgba(0, 0, 0, 0.1), 0 10rpx 30rpx rgba(0, 0, 0, 0.05);
  backdrop-filter: blur(20rpx);
  border: 1rpx solid rgba(255, 255, 255, 0.5);
  width: 100%;
  max-width: 600rpx;
  animation: slideUp 0.8s cubic-bezier(0.34, 1.56, 0.64, 1) forwards;
}

/* 奖项卡片头部 */
.award-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 30rpx;
  animation: fadeIn 0.6s ease 0.2s forwards;
  opacity: 0;
}

.award-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #333333;
}

.award-badge {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #ffffff;
  padding: 12rpx 24rpx;
  border-radius: 24rpx;
  font-size: 32rpx;
  font-weight: 700;
  box-shadow: 0 8rpx 24rpx rgba(102, 126, 234, 0.3);
  animation: pulse 1.5s ease-in-out infinite;
}

/* 奖项说明 */
.award-description {
  background: rgba(102, 126, 234, 0.08);
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
  text-align: center;
  animation: fadeIn 0.6s ease 0.3s forwards;
  opacity: 0;
}

.description-text {
  font-size: 28rpx;
  color: #666666;
  line-height: 40rpx;
}

.award-level {
  display: block;
  font-size: 48rpx;
  font-weight: 700;
  color: #667eea;
  margin-top: 16rpx;
  text-shadow: 0 4rpx 12rpx rgba(102, 126, 234, 0.3);
  animation: glow 2s ease-in-out infinite alternate;
}

/* 统计信息 */
.stats-container {
  display: flex;
  justify-content: space-between;
  margin-bottom: 30rpx;
  animation: fadeIn 0.6s ease 0.4s forwards;
  opacity: 0;
}

.stat-item {
  flex: 1;
  text-align: center;
  background: rgba(255, 255, 255, 0.9);
  border-radius: 20rpx;
  padding: 24rpx;
  margin: 0 10rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.08);
  transition: all 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
}

.stat-item:hover {
  transform: translateY(-4rpx);
  box-shadow: 0 8rpx 24rpx rgba(102, 126, 234, 0.2);
}

.stat-number {
  font-size: 48rpx;
  font-weight: 700;
  color: #667eea;
  margin-bottom: 8rpx;
  line-height: 1;
}

.stat-label {
  font-size: 24rpx;
  color: #666666;
}

/* 奖项说明文字 */
.award-info {
  animation: fadeIn 0.6s ease 0.5s forwards;
  opacity: 0;
}

.info-title {
  display: block;
  font-size: 32rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 20rpx;
}

.info-list {
  background: rgba(255, 255, 255, 0.9);
  border-radius: 20rpx;
  padding: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.08);
}

.info-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid rgba(0, 0, 0, 0.05);
}

.info-item:last-child {
  border-bottom: none;
}

.info-level {
  font-size: 28rpx;
  font-weight: 600;
  color: #333333;
}

.info-desc {
  font-size: 28rpx;
  color: #666666;
}

/* 提示信息 */
.tips {
  margin-top: 30rpx;
  text-align: center;
  animation: fadeIn 0.6s ease 0.6s forwards;
  opacity: 0;
}

.tips-text {
  font-size: 24rpx;
  color: #999999;
  line-height: 36rpx;
}

/* 动画效果 */
@keyframes fadeIn {
  from {
    opacity: 0;
    transform: translateY(20rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

@keyframes slideUp {
  from {
    opacity: 0;
    transform: translateY(40rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

@keyframes pulse {
  0%, 100% {
    transform: scale(1);
    box-shadow: 0 8rpx 24rpx rgba(102, 126, 234, 0.3);
  }
  50% {
    transform: scale(1.05);
    box-shadow: 0 12rpx 36rpx rgba(102, 126, 234, 0.4);
  }
}

@keyframes glow {
  from {
    text-shadow: 0 4rpx 12rpx rgba(102, 126, 234, 0.3);
  }
  to {
    text-shadow: 0 6rpx 20rpx rgba(102, 126, 234, 0.5);
  }
}