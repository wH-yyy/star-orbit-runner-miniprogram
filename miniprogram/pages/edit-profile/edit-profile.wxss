/* pages/edit-profile/edit-profile.wxss */
/* 全局样式重置 */
page {
  background-color: #f5f5f5;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
}

/* 主容器 */
.edit-profile-container {
  padding: 0 30rpx 60rpx;
}

/* 返回按钮 */
.back-button {
  position: absolute;
  left: 30rpx;
  top: 30rpx;
  z-index: 100;
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.back-arrow {
  font-size: 48rpx;
  color: #333333;
}

/* 表单容器 */
.profile-form {
  background-color: #ffffff;
  margin-top: 30rpx;
  border-radius: 16rpx;
  padding: 30rpx;
}

/* 表单项 */
.form-item {
  display: flex;
  align-items: center;
  padding: 30rpx 0;
  border-bottom: 1px solid #f0f0f0;
}

/* 最后一个表单项去除边框 */
.form-item:last-child {
  border-bottom: none;
}

/* 表单标签 */
.form-label {
  width: 160rpx;
  font-size: 32rpx;
  color: #333333;
}

/* 表单值 */
.form-value {
  flex: 1;
  font-size: 32rpx;
  color: #333333;
}

/* 头像容器 */
.avatar-container {
  display: flex;
  align-items: center;
}

/* 头像 */
.avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  margin-right: 24rpx;
}

/* 更换头像文字 */
.change-avatar {
  font-size: 28rpx;
  color: #07c160;
}

/* 输入框样式 */
input {
  font-size: 32rpx;
  color: #333333;
  width: 100%;
}

/* 保存按钮 */
.save-button {
  margin-top: 60rpx;
  padding: 0 30rpx;
}

/* 按钮样式 */
.save-button button {
  width: 100%;
  height: 90rpx;
  font-size: 34rpx;
  border-radius: 45rpx;
  background-color: #07c160;
  color: #ffffff;
}
