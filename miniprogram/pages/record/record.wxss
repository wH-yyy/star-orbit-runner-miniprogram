/* pages/record/record.wxss */
page {
  background: linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%);
  min-height: 100vh;
}

.record-container {
  padding: 20rpx;
  box-sizing: border-box;
  animation: fadeIn 0.4s ease forwards;
}

/* 用户信息卡片 */
.user-card {
  display: flex;
  align-items: center;
  background: rgba(255, 255, 255, 0.95);
  border-radius: 32rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 16rpx 50rpx rgba(0, 0, 0, 0.1), 0 8rpx 24rpx rgba(0, 0, 0, 0.06);
  backdrop-filter: blur(30rpx);
  border: 1rpx solid rgba(255, 255, 255, 0.8);
  transition: all 0.3s ease;
  animation: slideUp 0.6s cubic-bezier(0.34, 1.56, 0.64, 1) forwards;
}

.avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50rpx;
  margin-right: 20rpx;
  box-shadow: 0 8rpx 28rpx rgba(102, 126, 234, 0.3);
}

.user-info {
  flex: 1;
}

.name {
  font-size: 36rpx;
  font-weight: 800;
  color: #333;
  margin-bottom: 10rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  letter-spacing: -1rpx;
  text-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.08);
}

.stu-id {
  font-size: 28rpx;
  color: #666;
  font-weight: 500;
}

/* 统计数据卡片 */
.stats-card {
  display: flex;
  background: rgba(255, 255, 255, 0.95);
  border-radius: 32rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 16rpx 50rpx rgba(0, 0, 0, 0.1), 0 8rpx 24rpx rgba(0, 0, 0, 0.06);
  backdrop-filter: blur(30rpx);
  border: 1rpx solid rgba(255, 255, 255, 0.8);
  animation: slideUp 0.6s cubic-bezier(0.34, 1.56, 0.64, 1) 0.2s forwards;
  opacity: 0;
}

.stat-item {
  flex: 1;
  text-align: center;
  padding: 20rpx;
  border-radius: 24rpx;
  position: relative;
  overflow: hidden;
}

.stat-value {
  font-size: 48rpx;
  font-weight: 800;
  color: #667eea;
  margin-bottom: 10rpx;
  display: block;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  letter-spacing: -1rpx;
  animation: fadeIn 0.6s ease forwards;
}

.stat-label {
  font-size: 26rpx;
  color: #666;
  font-weight: 500;
  animation: fadeIn 0.6s ease 0.2s forwards;
  opacity: 0;
}

/* 筛选容器样式 */
.filter-container {
  background-color: #fff;
  margin: 10px 15px;
  padding: 15px;
  border-radius: 12px;
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.05);
}

.filter-section {
  margin-bottom: 20px;
}

.filter-label {
  font-size: 14px;
  color: #666;
  margin-bottom: 8px;
  font-weight: 500;
}

/* 日期筛选样式 */
.date-filter {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.date-picker {
  flex: 1;
  height: 40px;
  line-height: 40px;
  text-align: center;
  background-color: #f8f9fa;
  border-radius: 8px;
  color: #999;
  font-size: 14px;
}

.date-selected {
  background-color: #e6f7ff;
  color: #1890ff;
  font-weight: 500;
}

.date-separator {
  padding: 0 10px;
  color: #999;
  font-size: 14px;
}

/* 状态筛选样式 */
.status-filter {
  display: flex;
  flex-wrap: wrap;
  gap: 10px;
}

.status-option {
  padding: 8px 16px;
  background-color: #f8f9fa;
  border-radius: 20px;
  font-size: 13px;
  color: #666;
  text-align: center;
  min-width: 70px;
  transition: all 0.3s ease;
}

.status-active {
  background-color: #1890ff;
  color: #fff;
}

/* 筛选操作按钮样式 */
.filter-actions {
  display: flex;
  gap: 10px;
  margin-top: 20px;
}

.filter-btn {
  flex: 1;
  height: 40px;
  line-height: 40px;
  border: none;
  border-radius: 8px;
  font-size: 15px;
  transition: all 0.3s ease;
}

.filter-reset {
  background-color: #f8f9fa;
  color: #666;
}

.filter-apply {
  background-color: #1890ff;
  color: #fff;
}

.filter-reset:active {
  background-color: #e6e6e6;
}

.filter-apply:active {
  background-color: #096dd9;
}

/* 无筛选结果提示 */
.no-result {
  text-align: center;
  padding: 40px 0;
  color: #999;
  font-size: 14px;
}

/* 列表计数样式调整 */
.list-count {
  color: #1890ff;
  font-weight: 500;
}

/* 记录列表 */
.record-list {
  background: rgba(255, 255, 255, 0.95);
  border-radius: 32rpx;
  padding: 30rpx;
  box-shadow: 0 16rpx 50rpx rgba(0, 0, 0, 0.1), 0 8rpx 24rpx rgba(0, 0, 0, 0.06);
  backdrop-filter: blur(30rpx);
  border: 1rpx solid rgba(255, 255, 255, 0.8);
  animation: slideUp 0.6s cubic-bezier(0.34, 1.56, 0.64, 1) 0.4s forwards;
  opacity: 0;
}

/* 列表头部 */
.list-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
  padding-bottom: 20rpx;
  border-bottom: 2rpx solid rgba(0, 0, 0, 0.1);
}

.list-title {
  font-size: 36rpx;
  font-weight: 800;
  color: #333;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  letter-spacing: -1rpx;
  text-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.08);
}

.list-count {
  font-size: 26rpx;
  color: #666;
  font-weight: 500;
  background: rgba(102, 126, 234, 0.15);
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(102, 126, 234, 0.15);
}

.loading,
.empty {
  text-align: center;
  padding: 60rpx 0;
  color: #999;
  font-size: 28rpx;
}

.empty .submit-btn {
  margin-top: 20rpx;
  padding: 14rpx 0;
  background-color: #1890ff;
  color: #fff;
  border: none;
  border-radius: 8rpx;
  font-size: 26rpx;
  width: 240rpx;
  height: auto;
  line-height: normal;
}

.empty .submit-btn::after {
  border: none;
}

/* 列表样式 */
.record-list-container {
  border-radius: 16rpx;
  overflow: hidden;
  background: #fff;
}

/* 列表头部行 */
.list-header-row {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: white;
  font-weight: 600;
  font-size: 32rpx;
}

/* 列表行 */
.list-row {
  display: flex;
  align-items: center;
  padding: 24rpx 20rpx;
  border-bottom: 1rpx solid rgba(0, 0, 0, 0.06);
}

.list-row:last-child {
  border-bottom: none;
}

/* 添加点击效果 */
.list-row:active {
  background-color: rgba(102, 126, 234, 0.05);
}

/* 列表列 */
.list-col {
  padding: 0 10rpx;
}

.list-col-date {
  flex: 2;
  display: flex;
  flex-direction: column;
  justify-content: center;
  min-height: 80rpx;
}

.list-col-status {
  flex: 1;
  display: flex;
  justify-content: center;
}

.list-col-arrow {
  width: 60rpx;
  display: flex;
  justify-content: center;
  align-items: center;
}

/* 日期和时间样式 */
.date {
  font-size: 30rpx;
  color: #333;
  font-weight: 500;
  line-height: 1.4;
}

.time {
  font-size: 26rpx;
  color: #666;
  line-height: 1.3;
  margin-top: 4rpx;
}

/* 状态标签 */
.status-text {
  font-size: 28rpx;
  font-weight: 600;
  padding: 6rpx 20rpx;
  border-radius: 20rpx;
  text-align: center;
  min-width: 100rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

.status-passed {
  color: #52c41a;
  background: linear-gradient(135deg, rgba(82, 196, 26, 0.1) 0%, rgba(82, 196, 26, 0.15) 100%);
  border: 1rpx solid rgba(82, 196, 26, 0.3);
}

.status-failed {
  color: #ff4d4f;
  background: linear-gradient(135deg, rgba(255, 77, 79, 0.1) 0%, rgba(255, 77, 79, 0.15) 100%);
  border: 1rpx solid rgba(255, 77, 79, 0.3);
}

.status-pending {
  color: #faad14;
  background: linear-gradient(135deg, rgba(250, 173, 20, 0.1) 0%, rgba(250, 173, 20, 0.15) 100%);
  border: 1rpx solid rgba(250, 173, 20, 0.3);
}

/* 箭头样式 */
.arrow {
  font-size: 40rpx;
  color: #999;
  font-weight: 300;
}

/* 加载更多 */
.load-more,
.no-more {
  text-align: center;
  padding: 40rpx 0;
  color: #666;
  font-size: 26rpx;
  font-weight: 500;
  border-radius: 24rpx;
  margin-top: 20rpx;
  background: #fff;
}

.no-more {
  color: #999;
}

/* 动画效果 */
@keyframes fadeIn {
  from {
    opacity: 0;
    transform: translateY(20rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

@keyframes slideUp {
  from {
    opacity: 0;
    transform: translateY(40rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

/* 响应式设计 */
@media (max-width: 375px) {
  .record-container {
    padding: 16rpx;
  }
  
  .user-card,
  .stats-card,
  .record-list {
    padding: 24rpx;
  }
  
  .name {
    font-size: 32rpx;
  }
  
  .stu-id {
    font-size: 26rpx;
  }
  
  .stat-value {
    font-size: 40rpx;
  }
  
  .stat-label {
    font-size: 24rpx;
  }
  
  .list-title {
    font-size: 32rpx;
  }
  
  .list-row {
    padding: 20rpx 16rpx;
  }
  
  .date {
    font-size: 24rpx;
  }
  
  .time {
    font-size: 20rpx;
  }
  
  .status-text {
    font-size: 22rpx;
    padding: 4rpx 16rpx;
    min-width: 80rpx;
  }
  
  .arrow {
    font-size: 36rpx;
  }
  
  .list-col-arrow {
    width: 50rpx;
  }
}