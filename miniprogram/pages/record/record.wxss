/* pages/record/record.wxss */
page {
  background: linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%);
  min-height: 100vh;
}

.record-container {
  padding: 20rpx;
  box-sizing: border-box;
  animation: fadeIn 0.4s ease forwards;
}

/* 用户信息卡片 */
.user-card {
  display: flex;
  align-items: center;
  background: rgba(255, 255, 255, 0.95);
  border-radius: 32rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 16rpx 50rpx rgba(0, 0, 0, 0.1), 0 8rpx 24rpx rgba(0, 0, 0, 0.06);
  backdrop-filter: blur(30rpx);
  border: 1rpx solid rgba(255, 255, 255, 0.8);
  transition: all 0.3s ease;
  animation: slideUp 0.6s cubic-bezier(0.34, 1.56, 0.64, 1) forwards;
}

.avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50rpx;
  margin-right: 20rpx;
  box-shadow: 0 8rpx 28rpx rgba(102, 126, 234, 0.3);
}

.user-info {
  flex: 1;
}

.name {
  font-size: 36rpx;
  font-weight: 800;
  color: #333;
  margin-bottom: 10rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  letter-spacing: -1rpx;
  text-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.08);
}

.stu-id {
  font-size: 28rpx;
  color: #666;
  font-weight: 500;
}

/* 统计数据卡片 */
.stats-card {
  display: flex;
  background: rgba(255, 255, 255, 0.95);
  border-radius: 32rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 16rpx 50rpx rgba(0, 0, 0, 0.1), 0 8rpx 24rpx rgba(0, 0, 0, 0.06);
  backdrop-filter: blur(30rpx);
  border: 1rpx solid rgba(255, 255, 255, 0.8);
  animation: slideUp 0.6s cubic-bezier(0.34, 1.56, 0.64, 1) 0.2s forwards;
  opacity: 0;
}

.stat-item {
  flex: 1;
  text-align: center;
  border-radius: 24rpx;
  position: relative;
  overflow: hidden;
}

.stat-value {
  font-size: 48rpx;
  font-weight: 800;
  color: #667eea;
  margin-bottom: 10rpx;
  display: block;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  letter-spacing: -1rpx;
  animation: fadeIn 0.6s ease forwards;
}

.stat-label {
  font-size: 26rpx;
  color: #666;
  font-weight: 500;
  animation: fadeIn 0.6s ease 0.2s forwards;
  opacity: 0;
}

/* 跑步记录卡片 */
.record-card {
  background: rgba(255, 255, 255, 0.95);
  border-radius: 32rpx;
  box-shadow: 0 16rpx 50rpx rgba(0, 0, 0, 0.1), 0 8rpx 24rpx rgba(0, 0, 0, 0.06);
  backdrop-filter: blur(30rpx);
  border: 1rpx solid rgba(255, 255, 255, 0.8);
  animation: slideUp 0.6s cubic-bezier(0.34, 1.56, 0.64, 1) 0.4s forwards;
  opacity: 0;
  overflow: hidden;
}

/* 卡片头部 */
.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx 30rpx 20rpx;
  border-bottom: 2rpx solid rgba(102, 126, 234, 0.1);
}

.card-title {
  font-size: 36rpx;
  font-weight: 800;
  color: #333;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  letter-spacing: -1rpx;
  text-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.08);
}

.card-header-right {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.record-count {
  font-size: 26rpx;
  color: #666;
  font-weight: 500;
  background: rgba(102, 126, 234, 0.15);
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(102, 126, 234, 0.15);
}

.filter-toggle {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 10rpx 20rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 20rpx;
  color: white;
  font-size: 26rpx;
  font-weight: 500;
  box-shadow: 0 4rpx 16rpx rgba(102, 126, 234, 0.3);
  transition: all 0.3s ease;
}

.filter-icon {
  font-weight: 600;
}

.filter-arrow {
  font-size: 22rpx;
  transition: transform 0.3s ease;
}

.filter-arrow-up {
  transform: rotate(180deg);
}

/* 筛选面板 */
.filter-panel {
  max-height: 0;
  overflow: hidden;
  opacity: 0;
  background: rgba(255, 255, 255, 0.98);
  transition: all 0.4s ease;
  transform: translateY(-10rpx);
}

.filter-panel-show {
  max-height: 600rpx;
  opacity: 1;
  transform: translateY(0);
  padding: 0 30rpx 30rpx;
  border-bottom: 2rpx solid rgba(102, 126, 234, 0.1);
}

.filter-section {
  margin-bottom: 30rpx;
}

.filter-section:last-child {
  margin-bottom: 20rpx;
}

.filter-label {
  font-size: 28rpx;
  color: #333;
  margin-bottom: 16rpx;
  font-weight: 600;
}

/* 日期筛选样式 */
.date-filter {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.date-picker {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  text-align: center;
  background-color: #f8f9fa;
  border-radius: 16rpx;
  color: #999;
  font-size: 28rpx;
  transition: all 0.3s ease;
}

.date-selected {
  background: linear-gradient(135deg, rgba(102, 126, 234, 0.1) 0%, rgba(118, 75, 162, 0.1) 100%);
  color: #667eea;
  font-weight: 600;
  border: 1rpx solid rgba(102, 126, 234, 0.3);
}

.date-separator {
  color: #999;
  font-size: 28rpx;
}

/* 状态筛选样式 */
.status-filter {
  display: flex;
  gap: 16rpx;
}

.status-option {
  flex: 1;
  padding: 16rpx 0;
  background-color: #f8f9fa;
  border-radius: 16rpx;
  font-size: 26rpx;
  color: #666;
  text-align: center;
  transition: all 0.3s ease;
}

.status-active {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  font-weight: 600;
  box-shadow: 0 4rpx 16rpx rgba(102, 126, 234, 0.3);
}

/* 筛选操作按钮样式 */
.filter-actions {
  display: flex;
  gap: 20rpx;
  margin-top: 30rpx;
}

.filter-btn {
  flex: 1;
  height: 80rpx;
  border: none;
  border-radius: 16rpx;
  font-size: 28rpx;
  font-weight: 600;
  transition: all 0.3s ease;
  display: flex;
  align-items: center;
  justify-content: center;
}

.filter-reset {
  background-color: #f8f9fa;
  color: #666;
}

.filter-apply {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
}

/* 卡片内容区域 */
.card-content {
  padding: 20rpx 30rpx 30rpx;
}

.loading,
.empty {
  text-align: center;
  padding: 60rpx 0;
  color: #999;
  font-size: 28rpx;
}

.empty .submit-btn {
  margin-top: 20rpx;
  padding: 14rpx 0;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  border: none;
  border-radius: 16rpx;
  font-size: 26rpx;
  width: 240rpx;
  height: auto;
  line-height: normal;
}

.empty .submit-btn::after {
  border: none;
}

/* 列表样式 */
.record-list-container {
  border-radius: 16rpx;
  overflow: hidden;
  background: #fff;
}

/* 列表头部行 */
.list-header-row {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: white;
  font-weight: 600;
  font-size: 32rpx;
}

/* 列表行 */
.list-row {
  display: flex;
  align-items: center;
  padding: 24rpx 20rpx;
  border-bottom: 1rpx solid rgba(0, 0, 0, 0.06);
}

.list-row:last-child {
  border-bottom: none;
}

/* 列表列 */
.list-col {
  padding: 0 10rpx;
}

.list-col-date {
  flex: 2;
  display: flex;
  flex-direction: column;
  justify-content: center;
  min-height: 80rpx;
}

.list-col-status {
  flex: 1;
  display: flex;
  justify-content: center;
}

.list-col-arrow {
  width: 60rpx;
  display: flex;
  justify-content: center;
  align-items: center;
}

/* 日期和时间样式 */
.date {
  font-size: 30rpx;
  color: #333;
  font-weight: 500;
  line-height: 1.4;
}

.time {
  font-size: 26rpx;
  color: #666;
  line-height: 1.3;
  margin-top: 4rpx;
}

/* 状态样式 */
.status-passed {
  color: #07c160;
  background-color: rgba(7, 193, 96, 0.1);
}

.status-pending {
  color: #ff9f0a;
  background-color: rgba(255, 159, 10, 0.1);
}

.status-failed {
  color: #ff2b2b;
  background-color: rgba(255, 43, 43, 0.1);
}

.status-appeal {
  color: #007aff;
  background-color: rgba(0, 122, 255, 0.1);
}

.status-text {
  display: inline-block;
  padding: 8rpx 16rpx;
  border-radius: 24rpx;
  font-size: 24rpx;
  font-weight: 500;
}

/* 箭头样式 */
.arrow {
  font-size: 40rpx;
  color: #999;
  font-weight: 300;
}

/* 没有筛选结果时的提示 */
.no-result {
  text-align: center;
  padding: 40rpx 0;
  color: #999;
  font-size: 28rpx;
}

/* 动画效果 */
@keyframes fadeIn {
  from {
    opacity: 0;
    transform: translateY(20rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

@keyframes slideUp {
  from {
    opacity: 0;
    transform: translateY(40rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

/* 响应式设计 */
@media (max-width: 375rpx) {
  .record-container {
    padding: 16rpx;
  }
  
  .user-card,
  .stats-card,
  .record-card {
    padding: 24rpx;
    margin-bottom: 16rpx;
    border-radius: 24rpx;
  }
  
  .card-header {
    padding: 20rpx 24rpx 16rpx;
  }
  
  .filter-panel-show {
    padding: 0 24rpx 24rpx;
  }
  
  .card-content {
    padding: 16rpx 24rpx 24rpx;
  }
  
  .name,
  .card-title {
    font-size: 32rpx;
  }
  
  .stu-id {
    font-size: 26rpx;
  }
  
  .stat-value {
    font-size: 40rpx;
  }
  
  .avatar {
    width: 80rpx;
    height: 80rpx;
    border-radius: 40rpx;
    margin-right: 16rpx;
  }
  
  .filter-toggle {
    padding: 8rpx 16rpx;
    font-size: 24rpx;
  }
  
  .record-count {
    font-size: 24rpx;
    padding: 6rpx 16rpx;
  }
  
  .date-picker {
    height: 72rpx;
    line-height: 72rpx;
    font-size: 26rpx;
  }
  
  .filter-btn {
    height: 72rpx;
    font-size: 26rpx;
  }
  
  .list-row {
    padding: 20rpx 16rpx;
  }
  
  .date {
    font-size: 28rpx;
  }
  
  .time {
    font-size: 24rpx;
  }
}

/* 大屏设备适配 */
@media (min-width: 750rpx) {
  .record-container {
    max-width: 750rpx;
    margin: 0 auto;
  }
  
  .user-card,
  .stats-card,
  .record-card {
    border-radius: 40rpx;
  }
  
  .avatar {
    width: 120rpx;
    height: 120rpx;
    border-radius: 60rpx;
  }
  
  .name {
    font-size: 40rpx;
  }
  
  .stu-id {
    font-size: 30rpx;
  }
  
  .stat-value {
    font-size: 56rpx;
  }
  
  .stat-label {
    font-size: 28rpx;
  }
}
  
  
  .date {
    font-size: 24rpx;
  }
  
  .time {
    font-size: 20rpx;
  }
  
  .status-text {
    font-size: 22rpx;
    padding: 4rpx 16rpx;
    min-width: 80rpx;
  }
  
  .arrow {
    font-size: 36rpx;
  }
  
  .list-col-arrow {
    width: 50rpx;
  }
