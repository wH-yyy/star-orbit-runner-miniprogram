/* pages/record/record.wxss */
page {
  background-color: #f5f5f5;
}

.record-container {
  padding: 20rpx;
}

/* 用户信息卡片 */
.user-card {
  display: flex;
  align-items: center;
  background-color: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
}

.avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50rpx;
  margin-right: 20rpx;
}

.user-info {
  flex: 1;
}

.name {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 10rpx;
}

.stu-id {
  font-size: 28rpx;
  color: #999;
}

/* 统计数据卡片 */
.stats-card {
  display: flex;
  background-color: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
}

.stat-item {
  flex: 1;
  text-align: center;
}

.stat-value {
  font-size: 40rpx;
  font-weight: bold;
  color: #1890ff;
  margin-bottom: 10rpx;
}

.stat-label {
  font-size: 24rpx;
  color: #999;
}

/* 记录列表 */
.record-list {
  background-color: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
}

.list-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
}

.loading,
.empty {
  text-align: center;
  padding: 60rpx 0;
  color: #999;
  font-size: 28rpx;
}

.record-items {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.record-item {
  border-bottom: 1px solid #f0f0f0;
  padding-bottom: 20rpx;
}

.record-item:last-child {
  border-bottom: none;
}

.record-date {
  font-size: 28rpx;
  color: #333;
  margin-bottom: 10rpx;
}

.record-location {
  font-size: 26rpx;
  color: #666;
  margin-bottom: 15rpx;
}

.record-images {
  display: flex;
  gap: 10rpx;
  flex-wrap: wrap;
}

.record-image {
  width: 200rpx;
  height: 200rpx;
  border-radius: 8rpx;
}

/* 查看详情按钮 */
.view-detail-btn {
  margin-top: 15rpx;
  padding: 12rpx 0;
  background-color: #1890ff;
  color: #fff;
  border: none;
  border-radius: 8rpx;
  font-size: 26rpx;
  width: 180rpx;
  height: auto;
  line-height: normal;
}

.view-detail-btn::after {
  border: none;
}

.view-detail-btn:hover {
  background-color: #40a9ff;
}

.view-detail-btn:active {
  background-color: #096dd9;
}