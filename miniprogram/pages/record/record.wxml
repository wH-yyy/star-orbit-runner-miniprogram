<!--pages/record/record.wxml-->
<view class="record-container">
  <!-- 用户信息卡片 -->
  <view class="user-card">
    <image class="avatar" src="{{userInfo.avatar}}" mode="aspectFill"></image>
    <view class="user-info">
      <view class="name">{{userInfo.name}}</view>
      <view class="stu-id">学号：{{userInfo.stu_id}}</view>
    </view>
  </view>

  <!-- 统计数据 -->
  <view class="stats-card">
    <view class="stat-item">
      <view class="stat-value">{{userInfo.totalCount}}</view>
      <view class="stat-label">总次数</view>
    </view>
    <view class="stat-item">
      <view class="stat-value">{{userInfo.totalDistance}}</view>
      <view class="stat-label">总距离(km)</view>
    </view>
    <view class="stat-item">
      <view class="stat-value">{{userInfo.totalDuration}}</view>
      <view class="stat-label">总时长(分钟)</view>
    </view>
  </view>

  <!-- 跑步记录列表 -->
  <view class="record-list">
    <view class="list-header">
      <view class="list-title">跑步记录</view>
      <view class="list-count">{{recordList.length}}条记录</view>
    </view>
    
    <view wx:if="{{loading}}" class="loading">
      <text>加载中...</text>
    </view>
    
    <view wx:elif="{{recordList.length === 0}}" class="empty">
      <text>暂无跑步记录</text>
      <button class="submit-btn" bindtap="goToSubmit">去提交记录</button>
    </view>
    
    <view wx:else class="record-list-container">
      <!-- 列表头部 -->
      <view class="list-row list-header-row">
        <view class="list-col list-col-date">打卡时间</view>
        <view class="list-col list-col-status">状态</view>
        <view class="list-col list-col-arrow"></view>
      </view>
      
      <!-- 记录列表项 -->
      <view class="list-row" 
            wx:for="{{recordList}}" 
            wx:key="_id"
            bindtap="viewRecord" 
            data-id="{{item._id}}">
        <view class="list-col list-col-date">
          <view class="date">{{item.create_date}}</view>
          <view class="time">{{item.create_time_24}}</view>
        </view>
        <view class="list-col list-col-status">
          <view class="status-text {{item.status === 1 ? 'status-passed' : item.status === 2 ? 'status-pending' : 'status-failed'}}">
            {{item.status === 1 ? '已通过' : item.status === 2 ? '审核中' : '未通过'}}
          </view>
        </view>
        <view class="list-col list-col-arrow">
          <view class="arrow">›</view>
        </view>
      </view>
      
      <!-- 加载更多 -->
      <view wx:if="{{hasMore}}" class="load-more" bindtap="loadMoreData">
        <text>加载更多...</text>
      </view>
      <view wx:elif="{{!hasMore && recordList.length > 0}}" class="no-more">
        <text>没有更多记录了</text>
      </view>
    </view>
  </view>
</view>