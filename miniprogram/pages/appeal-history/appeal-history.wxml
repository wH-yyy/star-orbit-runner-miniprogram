<!--pages/appeal-history/appeal-history.wxml-->
<view class="appeal-container">
  <!-- 顶部导航 -->
  <view class="nav-bar">
    <view class="nav-title">
      <text class="title">申诉历史</text>
    </view>
  </view>
  
  <!-- 加载状态 -->
  <view wx:if="{{loading}}" class="loading-container">
    <view class="loading-spinner"></view>
    <text class="loading-text">加载申诉历史中...</text>
  </view>
  
  <!-- 空状态 -->
  <view wx:elif="{{!loading && appealList.length === 0}}" class="empty-container">
    <image src="/images/empty.png" class="empty-icon" mode="aspectFit"></image>
    <text class="empty-text">暂无申诉记录</text>
    <text class="empty-desc">您可以在跑步记录详情页提交申诉</text>
  </view>
  
  <!-- 申诉记录卡片 -->
  <view wx:else class="appeal-card">
    <!-- 卡片头部 -->
    <view class="card-header">
      <view class="card-title">申诉记录</view>
      <view class="record-count">{{appealList.length}}条记录</view>
    </view>
    
    <!-- 卡片内容 -->
    <view class="card-content">
      <!-- 列表头部 -->
      <view class="list-header-row">
        <view class="list-col list-col-time">提交时间</view>
        <view class="list-col list-col-status">状态</view>
        <view class="list-col list-col-arrow"></view>
      </view>
      
      <!-- 申诉列表项 -->
      <view class="list-row" 
            wx:for="{{appealList}}" 
            bindtap="viewRecordDetail" 
            data-index="{{index}}">
        <view class="list-col list-col-time">
          <view class="date">{{item.formattedDate}}</view>
          <view class="time">{{item.formattedTimeOnly}}</view>
        </view>
        <view class="list-col list-col-status">
          <view class="status-text {{item.statusClass}}">
            {{item.statusText}}
          </view>
        </view>
        <view class="list-col list-col-arrow">
          <view class="arrow">›</view>
        </view>
      </view>
      
      <!-- 没有记录时的提示 -->
      <view wx:if="{{appealList.length === 0}}" class="no-result">
        <text>没有找到符合条件的记录</text>
      </view>
    </view>
    
    <!-- 加载更多 -->
    <view wx:if="{{hasMore}}" class="load-more" bindtap="loadMoreAppeals">
      加载更多
    </view>
    <view wx:else class="no-more">
      没有更多记录了
    </view>
  </view>
</view>
