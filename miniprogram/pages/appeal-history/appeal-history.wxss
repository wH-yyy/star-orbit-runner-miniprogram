/* pages/appeal-history/appeal-history.wxss */

page {
  background: linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%);
  min-height: 100vh;
}

/* 页面容器 */
.appeal-container {
  padding: 20rpx;
  box-sizing: border-box;
  animation: fadeIn 0.4s ease forwards;
}

/* 顶部导航栏 */
.nav-bar {
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.95);
  border-radius: 32rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 16rpx 50rpx rgba(0, 0, 0, 0.1), 0 8rpx 24rpx rgba(0, 0, 0, 0.06);
  backdrop-filter: blur(30rpx);
  border: 1rpx solid rgba(255, 255, 255, 0.8);
  transition: all 0.3s ease;
  animation: slideUp 0.6s cubic-bezier(0.34, 1.56, 0.64, 1) forwards;
}

.nav-title {
  flex: 1;
  text-align: center;
}

.title {
  font-size: 36rpx;
  font-weight: 800;
  color: #333;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  letter-spacing: -1rpx;
  text-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.08);
}

/* 加载状态 */
.loading-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 80vh;
  padding: 0 40rpx;
  animation: slideUp 0.6s cubic-bezier(0.34, 1.56, 0.64, 1) 0.2s forwards;
  opacity: 0;
}

.loading-spinner {
  width: 96rpx;
  height: 96rpx;
  border: 10rpx solid rgba(102, 126, 234, 0.2);
  border-top: 10rpx solid #667eea;
  border-radius: 50%;
  animation: spin 1s linear infinite;
  margin-bottom: 36rpx;
  box-shadow: 0 6rpx 24rpx rgba(102, 126, 234, 0.3);
}

.loading-text {
  font-size: 32rpx;
  color: #666;
  text-align: center;
  line-height: 1.5;
  font-weight: 500;
}

@keyframes spin {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}

/* 空状态 */
.empty-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 80vh;
  padding: 0 40rpx;
  animation: slideUp 0.6s cubic-bezier(0.34, 1.56, 0.64, 1) 0.2s forwards;
  opacity: 0;
}

.empty-icon {
  width: 280rpx;
  height: 280rpx;
  margin-bottom: 36rpx;
  opacity: 0.8;
  animation: float 3s ease-in-out infinite;
  filter: drop-shadow(0 8rpx 32rpx rgba(102, 126, 234, 0.3));
}

@keyframes float {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-20rpx); }
}

.empty-text {
  font-size: 36rpx;
  font-weight: 800;
  color: #333;
  margin-bottom: 20rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.empty-desc {
  font-size: 26rpx;
  color: #666;
  text-align: center;
  line-height: 1.5;
  font-weight: 500;
}

/* 申诉记录卡片 */
.appeal-card {
  background: rgba(255, 255, 255, 0.95);
  border-radius: 32rpx;
  box-shadow: 0 16rpx 50rpx rgba(0, 0, 0, 0.1), 0 8rpx 24rpx rgba(0, 0, 0, 0.06);
  backdrop-filter: blur(30rpx);
  border: 1rpx solid rgba(255, 255, 255, 0.8);
  animation: slideUp 0.6s cubic-bezier(0.34, 1.56, 0.64, 1) 0.4s forwards;
  opacity: 0;
  overflow: hidden;
}

/* 卡片头部 */
.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx 30rpx 20rpx;
  border-bottom: 2rpx solid rgba(102, 126, 234, 0.1);
}

.card-title {
  font-size: 36rpx;
  font-weight: 800;
  color: #333;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  letter-spacing: -1rpx;
  text-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.08);
}

.record-count {
  font-size: 26rpx;
  color: #666;
  font-weight: 500;
  background: rgba(102, 126, 234, 0.15);
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(102, 126, 234, 0.15);
}

/* 卡片内容 */
.card-content {
  padding: 0;
}

/* 列表样式 */
.record-list-container {
  border-radius: 16rpx;
  overflow: hidden;
  background: #fff;
}

/* 列表头部行 */
.list-header-row {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: white;
  font-weight: 600;
  font-size: 32rpx;
  display: flex;
  align-items: center;
  padding: 24rpx 20rpx;
}

/* 列表行 */
.list-row {
  display: flex;
  align-items: center;
  padding: 24rpx 20rpx;
  border-bottom: 1rpx solid rgba(0, 0, 0, 0.06);
}

.list-row:last-child {
  border-bottom: none;
}

/* 列表列 */
.list-col {
  padding: 0 10rpx;
}

.list-col-time {
  flex: 2;
  display: flex;
  flex-direction: column;
  justify-content: center;
  min-height: 80rpx;
}

.list-col-status {
  flex: 1;
  display: flex;
  justify-content: center;
}

.list-col-arrow {
  width: 60rpx;
  display: flex;
  justify-content: center;
  align-items: center;
}

/* 日期和时间样式 */
.date {
  font-size: 30rpx;
  color: #333;
  font-weight: 500;
  line-height: 1.4;
}

.time {
  font-size: 26rpx;
  color: #666;
  line-height: 1.3;
  margin-top: 4rpx;
}

/* 状态样式 */
.status-text {
  display: inline-block;
  padding: 8rpx 20rpx;
  border-radius: 16rpx;
  font-size: 26rpx;
  font-weight: 500;
  text-align: center;
  min-width: 120rpx;
  transition: all 0.3s ease;
}

.status-pending {
  color: #faad14;
  background-color: rgba(250, 173, 20, 0.1);
}

.status-success {
  color: #52c41a;
  background-color: rgba(82, 196, 26, 0.1);
}

.status-failed {
  color: #ff4d4f;
  background-color: rgba(255, 77, 79, 0.1);
}

/* 箭头样式 */
.arrow {
  font-size: 40rpx;
  color: #999;
  font-weight: 300;
}

/* 没有记录时的提示 */
.no-result {
  text-align: center;
  padding: 60rpx 0;
  color: #999;
  font-size: 28rpx;
}

/* 加载更多 */
.load-more, .no-more {
  text-align: center;
  padding: 40rpx 0;
  color: #666;
  font-size: 26rpx;
  font-weight: 500;
  cursor: pointer;
  transition: all 0.3s ease;
  border-top: 1rpx solid rgba(102, 126, 234, 0.1);
}

.load-more:hover {
  background-color: rgba(102, 126, 234, 0.05);
  color: #667eea;
}

.no-more {
  cursor: default;
  color: #999;
  background-color: #f8f9fa;
}

/* 动画效果 */
@keyframes fadeIn {
  from {
    opacity: 0;
    transform: translateY(20rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

@keyframes slideUp {
  from {
    opacity: 0;
    transform: translateY(40rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

/* 响应式设计 */
@media (max-width: 375px) {
  .appeal-container {
    padding: 16rpx;
  }
  
  .nav-bar,
  .appeal-card {
    padding: 24rpx;
    margin-bottom: 16rpx;
  }
  
  .card-header {
    padding: 20rpx 24rpx 16rpx;
  }
  
  .title,
  .card-title {
    font-size: 32rpx;
  }
  
  .record-count {
    font-size: 24rpx;
    padding: 6rpx 16rpx;
  }
  
  .list-row {
    padding: 20rpx 16rpx;
  }
  
  .date {
    font-size: 24rpx;
  }
  
  .time {
    font-size: 20rpx;
  }
  
  .status-text {
    font-size: 22rpx;
    padding: 4rpx 16rpx;
    min-width: 80rpx;
  }
  
  .arrow {
    font-size: 36rpx;
  }
  
  .list-col-arrow {
    width: 50rpx;
  }
  
  .load-more,
  .no-more {
    padding: 32rpx 0;
    font-size: 24rpx;
  }
}
