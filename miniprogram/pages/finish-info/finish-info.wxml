<view class="container">
  <view class="header">
    <text class="title">完善个人信息</text>
    <text class="subtitle">请填写以下信息，以便我们为您提供更好的服务</text>
  </view>

  <form bindsubmit="formSubmit" class="form">
    <!-- 姓名 -->
    <view class="form-item">
      <text class="label">姓名</text>
      <input 
        name="name" 
        class="input" 
        placeholder="请输入真实姓名" 
        placeholder-class="placeholder"
        value="{{formData.name}}"
        bindinput="onInputChange"
        data-field="name"
      />
    </view>

    <!-- 学号 -->
    <view class="form-item">
      <text class="label">学号</text>
      <input 
        name="stu_id" 
        class="input" 
        placeholder="请输入学号" 
        placeholder-class="placeholder"
        value="{{formData.stu_id}}"
        bindinput="onInputChange"
        data-field="stu_id"
      />
    </view>

    <!-- 班级 -->
    <view class="form-item">
      <text class="label">班级</text>
      <input 
        name="class_name" 
        class="input" 
        placeholder="请输入班级" 
        placeholder-class="placeholder"
        value="{{formData.class_name}}"
        bindinput="onInputChange"
        data-field="class_name"
      />
    </view>

    <!-- 性别 -->
    <view class="form-item">
      <text class="label">性别</text>
      <radio-group class="radio-group" name="gender" bindchange="onRadioChange">
        <view class="radio-item" wx:for="{{genderOptions}}" wx:key="index">
          <radio value="{{item}}" checked="{{formData.gender === item}}" />
          <text class="radio-label">{{item}}</text>
        </view>
      </radio-group>
    </view>

    <!-- 书院 -->
    <view class="form-item">
      <text class="label">书院</text>
      <picker 
        name="college" 
        range="{{collegeOptions}}"
        bindchange="onPickerChange"
        data-field="college"
      >
        <view class="picker {{formData.college ? '' : 'picker-placeholder'}}">
          {{formData.college || '请选择书院'}}
        </view>
      </picker>
    </view>

    <!-- 校区 -->
    <view class="form-item">
      <text class="label">校区</text>
      <picker 
        name="campus" 
        range="{{campusOptions}}"
        bindchange="onPickerChange"
        data-field="campus"
      >
        <view class="picker {{formData.campus ? '' : 'picker-placeholder'}}">
          {{formData.campus || '请选择校区'}}
        </view>
      </picker>
    </view>
    <!-- 提交按钮 -->
    <button class="submit-btn" form-type="submit" hover-class="button-hover">
      提交信息
    </button>
  </form>
</view>