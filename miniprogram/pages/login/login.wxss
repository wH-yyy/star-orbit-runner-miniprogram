/* pages/login/login.wxss */
.container {
  display: flex;
  justify-content: center;
  align-items: center;
  flex-direction: column;
  height: 100vh;
  width: 100vw;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  padding: 0;
  margin: 0;
  box-sizing: border-box;
  position: fixed;
  top: 0;
  left: 0;
  overflow: hidden;
  transition: all 0.5s ease;
}

/* 增强背景效果 - 添加多层渐变和动态元素 */
.container::before {
  content: '';
  position: absolute;
  top: -50%;
  left: -50%;
  width: 200%;
  height: 200%;
  background: radial-gradient(circle, rgba(255,255,255,0.1) 1px, transparent 1px);
  background-size: 50rpx 50rpx;
  animation: float 20s linear infinite;
  z-index: 0;
}

.container::after {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: 
    radial-gradient(circle at 20% 50%, rgba(255,255,255,0.1) 0%, transparent 50%),
    radial-gradient(circle at 80% 20%, rgba(255,255,255,0.08) 0%, transparent 40%),
    radial-gradient(circle at 40% 80%, rgba(255,255,255,0.12) 0%, transparent 60%);
  animation: backgroundPulse 8s ease-in-out infinite;
  z-index: 0;
}

@keyframes backgroundPulse {
  0%, 100% {
    opacity: 0.6;
  }
  50% {
    opacity: 1;
  }
}

@keyframes float {
  0% {
    transform: translate(0, 0) rotate(0deg);
  }
  100% {
    transform: translate(50rpx, 50rpx) rotate(360deg);
  }
}

.form-item .error-tip {
  color: #f56c6c;
  font-size: 24rpx;
  margin-top: 8rpx;
  text-align: left;
  font-weight: 500;
}

.form-item .input-error {
  border-color: #f56c6c;
  background-color: #fff2f0;
  box-shadow: 0 4rpx 12rpx rgba(245, 108, 108, 0.15);
}

.form-item .input-error:focus {
  border-color: #f56c6c;
  background-color: #fff2f0;
  box-shadow: 0 6rpx 18rpx rgba(245, 108, 108, 0.2);
}

.login-box {
  width: 100%;
  max-width: 700rpx;
  height: auto;
  min-height: 80vh;
  background: rgba(255, 255, 255, 0.98);
  border-radius: 36rpx;
  box-shadow: 
    0 24rpx 80rpx rgba(0, 0, 0, 0.25), 
    0 10rpx 30rpx rgba(0, 0, 0, 0.15),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.8);
  padding: 120rpx 60rpx;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  position: relative;
  z-index: 1;
  backdrop-filter: blur(20rpx);
  animation: slideUp 0.8s cubic-bezier(0.25, 0.46, 0.45, 0.94) forwards;
  border: 2rpx solid rgba(255, 255, 255, 0.3);
  margin: 40rpx;
  transition: all 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
}

.login-box:hover {
  box-shadow: 
    0 32rpx 100rpx rgba(102, 126, 234, 0.3), 
    0 16rpx 40rpx rgba(102, 126, 234, 0.2),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.8);
  transform: translateY(-4rpx);
}

/* 增强背景效果 */
.container::after {
  content: '';
  position: absolute;
  top: -50%;
  right: -50%;
  width: 150%;
  height: 150%;
  background: radial-gradient(circle, rgba(255,255,255,0.15) 0%, transparent 70%);
  animation: rotate 25s linear infinite;
  opacity: 0.7;
  z-index: 0;
}

@keyframes rotate {
  from {
    transform: rotate(0deg);
  }
  to {
    transform: rotate(360deg);
  }
}

/* 添加更多背景装饰 */
.container .background-decoration {
  position: absolute;
  width: 300rpx;
  height: 300rpx;
  background: radial-gradient(circle, rgba(255,255,255,0.1) 0%, transparent 70%);
  border-radius: 50%;
  animation: float 15s ease-in-out infinite;
  z-index: 0;
}

.container .background-decoration:nth-child(1) {
  top: 10%;
  left: 10%;
  animation-delay: 0s;
}

.container .background-decoration:nth-child(2) {
  bottom: 10%;
  right: 15%;
  animation-delay: 5s;
  width: 200rpx;
  height: 200rpx;
}

.container .background-decoration:nth-child(3) {
  top: 50%;
  right: 10%;
  animation-delay: 10s;
  width: 150rpx;
  height: 150rpx;
}

@keyframes float {
  0%, 100% {
    transform: translate(0, 0) scale(1);
    opacity: 0.3;
  }
  50% {
    transform: translate(50rpx, -50rpx) scale(1.2);
    opacity: 0.6;
  }
}

@keyframes slideUp {
  0% {
    opacity: 0;
    transform: translateY(50rpx);
  }
  100% {
    opacity: 1;
    transform: translateY(0);
  }
}

.logo {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 80rpx;
  animation: pulse 1.2s cubic-bezier(0.68, -0.55, 0.265, 1.55) forwards;
  position: relative;
}

@keyframes pulse {
  0% {
    transform: scale(0.7);
    opacity: 0;
  }
  50% {
    transform: scale(1.15);
    opacity: 0.8;
  }
  100% {
    transform: scale(1);
    opacity: 1;
  }
}

.logo::before {
  content: '';
  position: absolute;
  width: 200rpx;
  height: 200rpx;
  background: radial-gradient(circle, rgba(255,255,255,0.3) 0%, transparent 70%);
  border-radius: 50%;
  animation: logoGlow 2s ease-in-out infinite alternate;
  z-index: -1;
}

@keyframes logoGlow {
  from {
    transform: scale(0.8);
    opacity: 0.5;
  }
  to {
    transform: scale(1);
    opacity: 0.8;
  }
}

.logo image {
  width: 160rpx;
  height: 160rpx;
  border-radius: 80rpx;
  margin-bottom: 32rpx;
  border: 8rpx solid rgba(255, 255, 255, 0.8);
  box-shadow: 0 16rpx 48rpx rgba(0, 0, 0, 0.2), 0 8rpx 24rpx rgba(0, 0, 0, 0.15);
  transition: all 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
  background-color: #ffffff;
}

.logo image:hover {
  transform: scale(1.12) rotate(5deg);
  box-shadow: 0 24rpx 64rpx rgba(0, 0, 0, 0.25), 0 12rpx 32rpx rgba(0, 0, 0, 0.2);
}

.logo .title {
  font-size: 48rpx;
  font-weight: 800;
  color: #333333;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  letter-spacing: 4rpx;
  text-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
  animation: titleGlow 2s ease-in-out infinite alternate;
}

@keyframes titleGlow {
  from {
    text-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
  }
  to {
    text-shadow: 0 6rpx 20rpx rgba(102, 126, 234, 0.3);
  }
}

.form {
  width: 100%;
  max-width: none;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 40rpx;
  margin: 0 auto;
}

.form-item {
  width: 100%;
  position: relative;
  animation: inputSlideIn 0.6s cubic-bezier(0.25, 0.46, 0.45, 0.94) forwards;
  opacity: 0;
}

.form-item:nth-child(1) {
  animation-delay: 0.2s;
}

.form-item:nth-child(2) {
  animation-delay: 0.4s;
}

@keyframes inputSlideIn {
  from {
    opacity: 0;
    transform: translateX(-20rpx);
  }
  to {
    opacity: 1;
    transform: translateX(0);
  }
}

.form-item .label {
  display: block;
  font-size: 30rpx;
  color: #444444;
  margin-bottom: 16rpx;
  font-weight: 600;
  transition: all 0.3s ease;
  letter-spacing: 1rpx;
}

.form-item .input {
  width: 100%;
  height: 100rpx;
  border: 3rpx solid transparent;
  border-radius: 24rpx;
  padding: 0 34rpx;
  box-sizing: border-box;
  font-size: 34rpx;
  color: #333333;
  background: linear-gradient(135deg, rgba(255,255,255,0.95) 0%, rgba(255,255,255,0.9) 100%);
  transition: all 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
  box-shadow: 
    0 4rpx 16rpx rgba(0, 0, 0, 0.08), 
    inset 0 2rpx 10rpx rgba(0, 0, 0, 0.05),
    0 0 0 1rpx rgba(102, 126, 234, 0.1);
  backdrop-filter: blur(10rpx);
  position: relative;
  overflow: hidden;
}

.form-item .input::before {
  content: '';
  position: absolute;
  top: 0;
  left: -100%;
  width: 100%;
  height: 100%;
  background: linear-gradient(90deg, transparent, rgba(102, 126, 234, 0.1), transparent);
  transition: all 0.6s ease;
  pointer-events: none;
}

.form-item .input:focus::before {
  left: 100%;
}

.form-item .input:focus {
  border-color: #667eea;
  box-shadow: 
    0 10rpx 30rpx rgba(102, 126, 234, 0.3), 
    inset 0 0 0 3rpx rgba(102, 126, 234, 0.1),
    0 0 0 1rpx rgba(102, 126, 234, 0.3);
  transform: translateY(-4rpx);
  background: rgba(255, 255, 255, 0.98);
  outline: none;
}

.form-item .placeholder {
  color: #999999;
  font-style: italic;
}

.form-item .input-error {
  border-color: #f56c6c;
  background: rgba(245, 108, 108, 0.05);
  box-shadow: 0 4rpx 16rpx rgba(245, 108, 108, 0.15), inset 0 2rpx 8rpx rgba(245, 108, 108, 0.05);
}

.form-item .input-error:focus {
  border-color: #f56c6c;
  box-shadow: 0 8rpx 24rpx rgba(245, 108, 108, 0.25), inset 0 0 0 3rpx rgba(245, 108, 108, 0.1);
  background: rgba(245, 108, 108, 0.05);
}

.form-item .error-tip {
  color: #f56c6c;
  font-size: 26rpx;
  margin-top: 12rpx;
  text-align: left;
  font-weight: 500;
  animation: shake 0.5s ease-in-out;
}

@keyframes shake {
  0%, 100% {
    transform: translateX(0);
  }
  25% {
    transform: translateX(-10rpx);
  }
  75% {
    transform: translateX(10rpx);
  }
}

.login-btn {
  width: 100%;
  max-width: 450rpx;
  height: 120rpx;
  font-size: 40rpx;
  font-weight: 700;
  border-radius: 32rpx;
  margin: 0;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #ffffff;
  box-shadow: 
    0 24rpx 72rpx rgba(102, 126, 234, 0.5), 
    0 12rpx 36rpx rgba(102, 126, 234, 0.4), 
    inset 0 2rpx 6rpx rgba(255, 255, 255, 0.25);
  transition: all 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
  position: relative;
  overflow: hidden;
  animation: buttonSlideIn 0.8s cubic-bezier(0.25, 0.46, 0.45, 0.94) forwards;
  opacity: 0;
  animation-delay: 0.6s;
  border: none;
  display: flex;
  justify-content: center;
  align-items: center;
  letter-spacing: 3rpx;
  text-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.1);
  z-index: 1;
}

@keyframes buttonSlideIn {
  from {
    opacity: 0;
    transform: translateY(30rpx) scale(0.95);
  }
  to {
    opacity: 1;
    transform: translateY(0) scale(1);
  }
}

.login-btn::before {
  content: '';
  position: absolute;
  top: 0;
  left: -100%;
  width: 100%;
  height: 100%;
  background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.35), transparent);
  transition: all 0.5s ease;
  transform: skewX(-20deg);
  z-index: -1;
}

.login-btn::after {
  content: '';
  position: absolute;
  top: 50%;
  left: 50%;
  width: 0;
  height: 0;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.2);
  transform: translate(-50%, -50%);
  transition: all 0.6s ease;
  z-index: -1;
}

.login-btn:hover {
  box-shadow: 
    0 32rpx 96rpx rgba(102, 126, 234, 0.6), 
    0 16rpx 48rpx rgba(102, 126, 234, 0.5), 
    inset 0 2rpx 8rpx rgba(255, 255, 255, 0.3);
  transform: translateY(-6rpx) scale(1.02);
}

.login-btn:hover::before {
  left: 100%;
}

.login-btn:hover::after {
  width: 300rpx;
  height: 300rpx;
}

.login-btn:active {
  transform: scale(0.98);
  box-shadow: 
    0 16rpx 48rpx rgba(102, 126, 234, 0.4), 
    0 8rpx 24rpx rgba(102, 126, 234, 0.3),
    inset 0 2rpx 6rpx rgba(255, 255, 255, 0.2);
}

.login-btn:active::after {
  width: 0;
  height: 0;
  transition: all 0.2s ease;
}

.login-btn[disabled] {
  background: linear-gradient(135deg, #cccccc 0%, #999999 100%);
  color: #ffffff;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.15);
  transform: none;
  cursor: not-allowed;
  text-shadow: none;
}

.login-btn[disabled]:active {
  transform: none;
}

.login-btn[disabled]:hover {
  transform: none;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.15);
  background: linear-gradient(135deg, #cccccc 0%, #999999 100%);
}

.login-btn[disabled]::before,
.login-btn[disabled]::after {
  display: none;
}

/* 添加一些装饰元素 */
.form-item::before {
  content: '';
  position: absolute;
  left: 0;
  top: -20rpx;
  width: 40rpx;
  height: 6rpx;
  background: linear-gradient(90deg, #667eea 0%, #764ba2 100%);
  border-radius: 3rpx;
  opacity: 0;
  transition: all 0.3s ease;
}

.form-item .input:focus + .error-tip + .form-item::before,
.form-item .input:focus + .form-item::before {
  opacity: 1;
}

/* 协议相关样式 */
.agreement {
  width: 100%;
  animation: fadeIn 1s cubic-bezier(0.25, 0.46, 0.45, 0.94) forwards;
  opacity: 0;
  animation-delay: 0.7s;
  position: relative;
  z-index: 1;
}

.checkbox-item {
  display: flex;
  align-items: center;
  cursor: pointer;
  user-select: none;
  width: 100%;
  margin: 8rpx 0;
}

/* 自定义checkbox容器 */
.custom-checkbox-container {
  display: inline-block;
  width: 36rpx;
  height: 36rpx;
  margin-right: 14rpx;
  vertical-align: middle;
  position: relative;
  top: 0;
}

/* 自定义checkbox样式 */
.custom-checkbox {
  width: 36rpx;
  height: 36rpx;
  border: 3rpx solid #e0e0e0;
  border-radius: 8rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
  background-color: #ffffff;
  vertical-align: middle;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.08);
}

/* 调整文字垂直对齐 */
.agreement-text {
  font-size: 28rpx;
  color: #555555;
  line-height: 36rpx;
  vertical-align: middle;
  display: inline-block;
  font-weight: 400;
}

.custom-checkbox.checked {
  background-color: #667eea;
  border-color: #667eea;
  box-shadow: 0 4rpx 12rpx rgba(102, 126, 234, 0.3);
  transform: scale(1.05);
}

.checkbox-inner {
  width: 20rpx;
  height: 12rpx;
  border: 2rpx solid #ffffff;
  border-top: none;
  border-right: none;
  transform: rotate(-45deg);
  transition: all 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
  opacity: 0;
  animation: checkboxCheck 0.3s ease forwards;
}

@keyframes checkboxCheck {
  from {
    opacity: 0;
    transform: rotate(-45deg) scale(0.5);
  }
  to {
    opacity: 1;
    transform: rotate(-45deg) scale(1);
  }
}

.agreement-text {
  font-size: 28rpx;
  color: #555555;
  line-height: 36rpx;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  display: inline-block;
  vertical-align: middle;
  max-width: calc(100% - 50rpx);
}

.agreement-link {
  color: #667eea;
  font-weight: 600;
  cursor: pointer;
  text-decoration: underline;
  text-decoration-color: #667eea;
  text-decoration-thickness: 2rpx;
  transition: all 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
  position: relative;
  padding: 3rpx 8rpx;
  border-radius: 8rpx;
  margin: 0 2rpx;
}

.agreement-link:hover {
  color: #764ba2;
  background: rgba(102, 126, 234, 0.15);
  text-decoration: none;
  transform: translateY(-1rpx);
  box-shadow: 0 2rpx 8rpx rgba(102, 126, 234, 0.2);
}

.agreement-link::after {
  content: '';
  position: absolute;
  left: 0;
  bottom: 0;
  width: 0;
  height: 2rpx;
  background: linear-gradient(90deg, #667eea 0%, #764ba2 100%);
  transition: all 0.3s ease;
  border-radius: 1rpx;
}

.agreement-link:hover::after {
  width: 100%;
}

/* 添加一些粒子装饰效果 */
.particle {
  position: absolute;
  width: 4rpx;
  height: 4rpx;
  background: rgba(255, 255, 255, 0.5);
  border-radius: 50%;
  animation: floatParticle 6s ease-in-out infinite;
  z-index: 0;
}

@keyframes floatParticle {
  0%, 100% {
    transform: translateY(0) rotate(0deg);
    opacity: 0;
  }
  50% {
    opacity: 1;
  }
  100% {
    transform: translateY(-100vh) rotate(360deg);
  }
}
