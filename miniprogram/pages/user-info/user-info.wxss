/* pages/edit-profile/edit-profile.wxss */
/* 全局样式重置 */
page {
  background-color: #f5f5f5;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
}

/* 主容器 */
.edit-profile-container {
  padding: 30rpx 30rpx 60rpx;
}

/* 统计数据卡片 */
.stats-card {
  display: flex;
  background-color: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
}

.stat-item {
  flex: 1;
  text-align: center;
}

.stat-value {
  font-size: 40rpx;
  font-weight: bold;
  color: #1890ff;
  margin-bottom: 10rpx;
}

.stat-label {
  font-size: 24rpx;
  color: #999;
}

/* 表单容器 */
.profile-form {
  background-color: #ffffff;
  border-radius: 16rpx;
  overflow: hidden;
}

/* 表单项 */
.form-item {
  display: flex;
  align-items: center;
  padding: 30rpx 24rpx;
  border-bottom: 1px solid #f0f0f0;
}

/* 头像表单项特殊样式 */
.form-item.avatar-item {
  padding: 40rpx 24rpx;
}

/* 最后一个表单项去除边框 */
.form-item:last-child {
  border-bottom: none;
}

/* 表单标签 */
.form-label {
  width: 160rpx;
  font-size: 32rpx;
  color: #333333;
  flex-shrink: 0;
}

/* 表单值 */
.form-value {
  flex: 1;
  font-size: 32rpx;
  color: #333333;
}

/* 头像包装器 */
.avatar-wrapper {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

/* 头像图片 */
.avatar-image {
  width: 120rpx;
  height: 120rpx;
  border-radius: 60rpx;
  background-color: #f0f0f0;
}

/* 头像提示文字 */
.avatar-tip {
  font-size: 28rpx;
  color: #999999;
}

/* 禁用状态 */
.form-value.disabled {
  display: flex;
  align-items: center;
}

.disabled-text {
  color: #999999;
}

.tip-text {
  font-size: 24rpx;
  color: #999999;
  margin-left: 12rpx;
}

/* picker样式 */
.picker {
  color: #333333;
}

/* 输入框样式 */
input {
  font-size: 32rpx;
  color: #333333;
  width: 100%;
}

/* 密码区域 */
.password-section {
  background-color: #ffffff;
  margin-top: 30rpx;
  border-radius: 16rpx;
  overflow: hidden;
}

/* 区域标题 */
.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx 24rpx;
  cursor: pointer;
}

.section-title {
  font-size: 32rpx;
  color: #333333;
  font-weight: bold;
}

.toggle-icon {
  font-size: 24rpx;
  color: #666666;
}

/* 密码表单 */
.password-form {
  border-top: 1px solid #f0f0f0;
}

/* 密码输入框 */
.password-input {
  display: flex;
  align-items: center;
  position: relative;
}

.password-input input {
  flex: 1;
  padding-right: 60rpx;
}

.eye-icon {
  position: absolute;
  right: 0;
  font-size: 40rpx;
  padding: 0 10rpx;
}

/* 保存按钮 */
.save-button {
  margin-top: 60rpx;
}

/* 按钮样式 */
.save-button button {
  background-color: #07c160;
  color: #ffffff;
  border-radius: 8rpx;
  font-size: 32rpx;
  height: 88rpx;
  line-height: 88rpx;
  width: 100%;
}
