/* pages/edit-profile/edit-profile.wxss */
/* 全局样式重置 */
page {
  background-color: #f5f5f5;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
}

/* 主容器 */
.edit-profile-container {
  padding: 30rpx 30rpx 60rpx;
}

/* 表单容器 */
.profile-form {
  background-color: #ffffff;
  border-radius: 16rpx;
  overflow: hidden;
}

/* 表单项 */
.form-item {
  display: flex;
  align-items: center;
  padding: 30rpx 24rpx;
  border-bottom: 1px solid #f0f0f0;
}

/* 头像表单项特殊样式 */
.form-item.avatar-item {
  padding: 40rpx 24rpx;
}

/* 最后一个表单项去除边框 */
.form-item:last-child {
  border-bottom: none;
}

/* 表单标签 */
.form-label {
  width: 160rpx;
  font-size: 32rpx;
  color: #333333;
  flex-shrink: 0;
}

/* 表单值 */
.form-value {
  flex: 1;
  font-size: 32rpx;
  color: #333333;
  display: flex;
  align-items: center;
}

/* 头像包装器 */
.avatar-wrapper {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

/* 头像图片 */
.avatar-image {
  width: 120rpx;
  height: 120rpx;
  border-radius: 60rpx;
  background-color: #f0f0f0;
}

/* 头像提示文字 */
.avatar-tip {
  font-size: 28rpx;
  color: #999999;
}

/* 禁用状态 */
.form-value.disabled {
  display: flex;
  align-items: center;
}

.disabled-text {
  color: #999999;
}

.tip-text {
  font-size: 24rpx;
  color: #999999;
  margin-left: 12rpx;
}

/* picker样式 */
.picker {
  color: #333333;
}

/* 输入框样式 */
input {
  font-size: 32rpx;
  color: #333333;
  width: 100%;
}

/* 密码区域 */
.password-section {
  background-color: #ffffff;
  margin-top: 30rpx;
  border-radius: 16rpx;
  overflow: hidden;
}

/* 区域标题 */
.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx 24rpx;
  cursor: pointer;
}

.section-title {
  font-size: 32rpx;
  color: #333333;
  font-weight: bold;
}

.toggle-icon {
  font-size: 24rpx;
  color: #666666;
}

/* 密码表单 */
.password-form {
  border-top: 1px solid #f0f0f0;
}

/* 密码输入框 */
.password-input {
  display: flex;
  align-items: center;
  position: relative;
}

.password-input input {
  flex: 1;
  padding-right: 60rpx;
}

.eye-icon {
  position: absolute;
  right: 0;
  font-size: 40rpx;
  padding: 0 10rpx;
}

/* 保存按钮 */
.save-button {
  margin-top: 60rpx;
}

/* 按钮样式 */
.save-button button {
  background-color: #07c160;
  color: #ffffff;
  border-radius: 8rpx;
  font-size: 32rpx;
  height: 88rpx;
  line-height: 88rpx;
  width: 100%;
  text-align: center;
  display: flex;
  justify-content: center;
  align-items: center;
}

/* 手机号显示样式 */
.phone-display {
  font-size: 32rpx;
  color: #333333;
  flex: 1;
}

/* 手机号显示容器 */
.phone-display-container {
  display: flex;
  align-items: center;
  justify-content: space-between;
  width: 100%;
  padding: 20rpx;
  background-color: #f8f8f8;
  border-radius: 8rpx;
  box-sizing: border-box;
  cursor: pointer;
  transition: background-color 0.3s ease;
}

.phone-display-container:hover {
  background-color: #f0f0f0;
}

/* 点击换绑提示 */
.change-phone-hint {
  font-size: 26rpx;
  color: #07c160;
  padding: 10rpx 20rpx;
  border: 1px solid #07c160;
  border-radius: 20rpx;
  background-color: transparent;
  font-weight: 500;
}

/* 手机号换绑表单 */
.phone-change-form {
  width: 100%;
  height: 100%;
  padding: 10rpx;
  background-color: #f8f8f8;
  border-radius: 12rpx;
  box-sizing: border-box;
  margin-top: 10rpx;
}

/* 新手机号输入框 */
.new-phone-input {
  width: 95%;
  height: 100%;
  margin: 10rpx;
  padding: 10rpx;
  background-color: #ffffff;
  border-radius: 8rpx;
  border: 1px solid #e0e0e0;
  font-size: 32rpx;
  box-sizing: border-box;
}

/* 验证码容器 */
.verification-code-container {
  height: 100%;
  display: flex;
  align-items: center;
  margin-bottom: 25rpx;
  gap: 15rpx;
}

/* 验证码输入框 */
.verification-input {
  height: 100%;
  flex: 1;
  padding: 10rpx;
  margin: 10rpx;
  background-color: #ffffff;
  border-radius: 8rpx;
  border: 1px solid #e0e0e0;
  font-size: 32rpx;
  box-sizing: border-box;
}

/* 获取验证码按钮 */
.get-code-btn {
  height: 100%;
  font-size: 28rpx;
  padding: 12rpx 24rpx;
  line-height: 46rpx;
  text-align: center;
  display: flex;
  justify-content: center;
  align-items: center;
}

/* 手机号换绑按钮组 */
.phone-change-buttons {
  display: flex;
  justify-content: flex-end;
  gap: 20rpx;
  margin-top: 10rpx;
}

/* 取消和确认按钮 */
.cancel-btn, .confirm-btn {
  font-size: 28rpx;
  padding: 12rpx 28rpx;
  height: 100%;
}

.cancel-btn {
  background-color: #ffffff;
  color: #666666;
  border: 1px solid #e0e0e0;
}

.confirm-btn {
  background-color: #07c160;
  color: #ffffff;
}

/* 密码类型选择器 */
.password-type-selector {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
  padding-bottom: 15rpx;
  border-bottom: 1px solid #e0e0e0;
}

/* 密码类型 */
.password-type {
  font-size: 28rpx;
  font-weight: bold;
  color: #333333;
}

/* 忘记密码 */
.forgot-password {
  font-size: 26rpx;
  color: #07c160;
  cursor: pointer;
  padding: 10rpx 15rpx;
  border-radius: 16rpx;
  text-align: center;
  min-width: 100rpx;
}

/* 密码表单底部 */
.password-form-footer {
  display: flex;
  justify-content: flex-end;
  padding: 20rpx 24rpx 30rpx;
  margin-top: 10rpx;
}

/* 禁用输入框 */
.disabled-input {
  color: #999999;
  background-color: #f5f5f5;
  border: 1px solid #e0e0e0;
  padding: 15rpx;
  border-radius: 8rpx;
}

/* 忘记密码验证码样式 */
.verification-code {
  justify-content: space-between;
  gap: 10rpx;
}
