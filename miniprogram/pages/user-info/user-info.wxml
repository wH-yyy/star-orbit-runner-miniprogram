<!--pages/edit-profile/edit-profile.wxml-->
<view class="edit-profile-container">
  <!-- 个人信息编辑表单 -->
  <view class="profile-form">
    <!-- 头像 -->
    <view class="form-item">
      <text class="form-label">头像</text>
      <view class="form-value avatar-container">
        <image class="avatar" src="{{userInfo.avatar}}" mode="aspectFill"></image>
        <text class="change-avatar">更换</text>
      </view>
    </view>

    <!-- 姓名 -->
    <view class="form-item">
      <text class="form-label">姓名</text>
      <view class="form-value">
        <input type="text" value="{{userInfo.name}}" placeholder="请输入姓名" />
      </view>
    </view>

    <!-- 学号 -->
    <view class="form-item">
      <text class="form-label">学号</text>
      <view class="form-value">
        <input type="text" value="{{userInfo.studentId}}" placeholder="请输入学号" />
      </view>
    </view>

    <!-- 校区 -->
        <view class="form-item">
              <text class="form-label">校区</text>
              <view class="form-value">
                <picker bindchange="onCampusChange" value="{{campusIndex}}" range="{{campusList}}">
                  <view class="picker">{{userInfo.campus || campusList[0]}}</view>
                </picker>
              </view>
            </view>

    <!-- 书院 -->
    <view class="form-item">
      <text class="form-label">书院</text>
      <view class="form-value">
        <picker bindchange="onAcademyChange" value="{{academyIndex}}" range="{{academyList}}">
          <view class="picker">{{userInfo.academy || academyList[0]}}</view>
        </picker>
      </view>
    </view>

    <!-- 班级 -->
    <view class="form-item">
      <text class="form-label">班级</text>
      <view class="form-value">
        <input type="text" value="{{userInfo.className}}" placeholder="请输入班级" />
      </view>
    </view>
  </view>

  <!-- 保存按钮 -->
  <view class="save-button">
    <button type="primary" size="default">保存</button>
  </view>
</view>