<!--pages/edit-profile/edit-profile.wxml-->
<view class="edit-profile-container">
  <!-- 个人信息编辑表单 -->
  <view class="profile-form">
    <!-- 姓名 -->
    <view class="form-item">
      <text class="form-label">姓名</text>
      <view class="form-value">
        <input 
          type="text" 
          value="{{userInfo.name}}" 
          placeholder="请输入姓名"
          data-field="name"
          bindinput="onInputChange" />
      </view>
    </view>

    <!-- 学号（联系管理员修改） -->
    <view class="form-item">
      <text class="form-label">学号</text>
      <view class="form-value disabled">
        <text class="disabled-text">{{userInfo.studentId}}</text>
        <text class="tip-text">（请联系管理员修改）</text>
      </view>
    </view>

    <!-- 性别 -->
    <view class="form-item">
      <text class="form-label">性别</text>
      <view class="form-value">
        <picker 
          mode="selector" 
          range="{{genderOptions}}" 
          value="{{genderIndex}}"
          bindchange="onGenderChange">
          <view class="picker">
            {{userInfo.gender || '请选择性别'}}
          </view>
        </picker>
      </view>
    </view>

    <!-- 校区 -->
    <view class="form-item">
      <text class="form-label">校区</text>
      <view class="form-value">
        <picker 
          mode="selector" 
          range="{{campusOptions}}" 
          value="{{campusIndex}}"
          bindchange="onCampusChange">
          <view class="picker">
            {{userInfo.campus || '请选择校区'}}
          </view>
        </picker>
      </view>
    </view>

    <!-- 书院 -->
    <view class="form-item">
      <text class="form-label">书院</text>
      <view class="form-value">
        <picker 
          mode="selector" 
          range="{{collegeOptions}}" 
          value="{{collegeIndex}}"
          bindchange="onCollegeChange">
          <view class="picker">
            {{userInfo.college || '请选择书院'}}
          </view>
        </picker>
      </view>
    </view>

    <!-- 班级 -->
    <view class="form-item">
      <text class="form-label">班级</text>
      <view class="form-value">
        <input 
          type="text" 
          value="{{userInfo.className}}" 
          placeholder="请输入班级"
          data-field="className"
          bindinput="onInputChange" />
      </view>
    </view>

    <!-- 手机号 -->
    <view class="form-item">
      <text class="form-label">手机号</text>
      <view class="form-value">
        <view wx:if="!isChangingPhone" class="phone-display-container">
          <text class="phone-display">{{userInfo.phone}}</text>
          <button class="change-phone-btn" bindtap="startChangePhone">换绑</button>
        </view>
        <view wx:else class="phone-change-form">
          <input 
            type="number" 
            value="{{newPhone}}" 
            placeholder="请输入新手机号"
            maxlength="11"
            bindinput="onNewPhoneInput" 
            class="new-phone-input"/>
          <view class="verification-code-container">
            <input 
              type="digit 
              value="{{verificationCode || ''}}" 
              placeholder="请输入验证码"
              maxlength="6"
              bindinput="onVerificationCodeInput" 
              class="verification-input"/>
            <button 
              class="get-code-btn" 
              bindtap="getVerificationCode"
              disabled="{{countdown > 0 || !isValidPhone}}"
              type="primary"
              size="mini">
              {{countdown &gt; 0 ? countdown + 's后重发' : '获取验证码'}}
            </button>
          </view>
          <view class="phone-change-buttons">
            <button class="cancel-btn" bindtap="cancelChangePhone" type="default" size="mini">取消</button>
            <button class="confirm-btn" bindtap="confirmChangePhone" type="primary" size="mini">确认</button>
          </view>
        </view>
      </view>
    </view>
  </view>

  <!-- 修改密码区域 -->
  <view class="password-section">
    <view class="section-header" bindtap="togglePasswordChange">
      <text class="section-title">修改密码</text>
      <text class="toggle-icon">{{isChangingPassword ? '▲' : '▼'}}</text>
    </view>
    
    <view class="password-form" wx:if="{{isChangingPassword}}">
      <!-- 忘记密码模式 -->
      <view wx:if="{{isForgotPassword}}">
        <view class="form-item">
          <text class="form-label">手机号</text>
          <view class="form-value">
            <input 
              type="number" 
              value="{{userInfo.phone}}" 
              placeholder="请输入手机号"
              maxlength="11"
              disabled="true"
              class="disabled-input"/>
          </view>
        </view>
        <view class="form-item">
          <text class="form-label">验证码</text>
          <view class="form-value password-input verification-code">
            <input 
              type="number" 
              value="{{forgotPasswordCode}}" 
              placeholder="请输入验证码"
              maxlength="6"
              bindinput="onForgotPasswordCodeInput" />
            <button 
              class="get-code-btn" 
              bindtap="getForgotPasswordCode"
              disabled="{{forgotPasswordCountdown > 0}}"
              type="primary"
              size="mini">
              {{forgotPasswordCountdown > 0 ? forgotPasswordCountdown + 's后重发' : '获取验证码'}}
            </button>
          </view>
        </view>
      </view>
      
      <!-- 旧密码（仅在非忘记密码模式显示） -->
      <view class="form-item" wx:if="{{!isForgotPassword}}">
        <text class="form-label">旧密码</text>
        <view class="form-value password-input">
          <input 
            password="{{!showOldPassword}}"
            value="{{passwordData.oldPassword}}" 
            placeholder="请输入旧密码"
            data-field="oldPassword"
            bindinput="onPasswordInput" />
          <text 
            class="eye-icon" 
            bindtap="togglePasswordVisibility"
            data-field="showOldPassword">
            {{showOldPassword ? '👁️' : '👁️‍🗨️'}}
          </text>
        </view>
      </view>

      <!-- 新密码 -->
      <view class="form-item">
        <text class="form-label">新密码</text>
        <view class="form-value password-input">
          <input 
            password="{{!showNewPassword}}"
            value="{{passwordData.newPassword}}" 
            placeholder="8-20位，含字母和数字"
            data-field="newPassword"
            bindinput="onPasswordInput" />
          <text 
            class="eye-icon" 
            bindtap="togglePasswordVisibility"
            data-field="showNewPassword">
            {{showNewPassword ? '👁️' : '👁️‍🗨️'}}
          </text>
        </view>
      </view>

      <!-- 确认新密码 -->
      <view class="form-item">
        <text class="form-label">确认密码</text>
        <view class="form-value password-input">
          <input 
            password="{{!showConfirmPassword}}"
            value="{{passwordData.confirmPassword}}" 
            placeholder="再次输入新密码"
            data-field="confirmPassword"
            bindinput="onPasswordInput" />
          <text 
            class="eye-icon" 
            bindtap="togglePasswordVisibility"
            data-field="showConfirmPassword">
            {{showConfirmPassword ? '👁️' : '👁️‍🗨️'}}
          </text>
        </view>
      </view>
      
      <view wx:if="{{isForgotPassword}}" class="password-form-footer">
          <view class="forgot-password" bindtap="cancelForgotPassword">使用旧密码修改</view>
      </view>

      <!-- 忘记密码按钮（仅在非忘记密码模式显示） -->
      <view wx:if="{{!isForgotPassword}}" class="password-form-footer">
        <view class="forgot-password" bindtap="startForgotPassword">忘记密码？</view>
      </view>
    </view>
  </view>

  <!-- 保存按钮 -->
  <view class="save-button">
    <button type="primary" size="default" bindtap="saveUserInfo">保存</button>
  </view>
</view>