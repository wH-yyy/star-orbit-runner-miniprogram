/* pages/record-detail/record-detail.wxss */
page {
  background: linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%);
  background-attachment: fixed;
  min-height: 100vh;
}

.container {
  min-height: 100vh;
  padding: 20rpx;
  box-sizing: border-box;
}

.loading-container {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 200rpx 0;
}

.loading-spinner {
  width: 80rpx;
  height: 80rpx;
  border: 8rpx solid rgba(102, 126, 234, 0.2);
  border-top: 8rpx solid #667eea;
  border-radius: 50%;
  animation: spin 1s linear infinite;
  margin-bottom: 32rpx;
}

.loading-text {
  font-size: 28rpx;
  color: #666666;
}

@keyframes spin {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}

.detail-container {
  margin: 0 auto;
  max-width: 800rpx;
  width: 100%;
  box-sizing: border-box;
  animation: slideUp 0.6s cubic-bezier(0.34, 1.56, 0.64, 1) forwards;
}

/* ========== 卡片样式 ========== */
.header-card,
.data-card,
.result-card,
.appeal-detail-card {
  background: rgba(255, 255, 255, 0.95);
  border-radius: 24rpx;
  padding: 28rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.08), 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
  backdrop-filter: blur(30rpx);
  border: 1rpx solid rgba(255, 255, 255, 0.8);
}

.card-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #333333;
  margin-bottom: 20rpx;
  display: block;
  background: linear-gradient(135deg, #5783c5 0%, #4276c4 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

/* ========== 头部卡片 - 时间和状态 ========== */
.time-status-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.time-info {
  flex: 1;
}

.time-label {
  display: block;
  font-size: 24rpx;
  color: #999999;
  margin-bottom: 8rpx;
}

.time-value {
  display: block;
  font-size: 32rpx;
  font-weight: 600;
  color: #333333;
}

.status-indicator {
  padding: 12rpx 20rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
  font-weight: 600;
  white-space: nowrap;
}

.status-indicator.status-passed {
  background: linear-gradient(135deg, rgba(82, 196, 26, 0.15) 0%, rgba(115, 209, 61, 0.15) 100%);
  border: 1rpx solid rgba(82, 196, 26, 0.3);
}

.status-indicator.status-pending {
  background: linear-gradient(135deg, rgba(250, 140, 22, 0.15) 0%, rgba(255, 169, 64, 0.15) 100%);
  border: 1rpx solid rgba(250, 140, 22, 0.3);
}

.status-indicator.status-failed {
  background: linear-gradient(135deg, rgba(255, 77, 79, 0.15) 0%, rgba(255, 120, 117, 0.15) 100%);
  border: 1rpx solid rgba(255, 77, 79, 0.3);
}

.status-indicator.status-appeal {
  background: linear-gradient(135deg, rgba(64, 158, 255, 0.15) 0%, rgba(102, 126, 234, 0.15) 100%);
  border: 1rpx solid rgba(102, 126, 234, 0.3);
}

.status-text {
  display: block;
}

.status-indicator.status-passed .status-text {
  color: #52c41a;
}

.status-indicator.status-pending .status-text {
  color: #fa8c16;
}

.status-indicator.status-failed .status-text {
  color: #ff4d4f;
}

.status-indicator.status-appeal .status-text {
  color: #667eea;
}

/* ========== 图片容器 ========== */
.image-container {
  text-align: center;
  margin-bottom: 32rpx;
  padding: 0 20rpx;
}

/* ========== 打卡图片 ========== */
.detail-image-title {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #333333;
  text-align: center;
  margin-bottom: 20rpx;
  background: linear-gradient(135deg, #5783c5 0%, #4276c4 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.detail-image {
  max-width: 100%;
  height: auto;
  border-radius: 20rpx;
  box-shadow: 0 12rpx 32rpx rgba(0, 0, 0, 0.15);
  display: block;
  margin: 0 auto;
}

/* ========== 步数截图 ========== */
.step-image-title {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #333333;
  text-align: center;
  margin-bottom: 20rpx;
  background: linear-gradient(135deg, #5783c5 0%, #4276c4 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.step-image {
  max-width: 100%;
  height: auto;
  border-radius: 20rpx;
  box-shadow: 0 12rpx 32rpx rgba(0, 0, 0, 0.15);
  display: block;
  margin: 0 auto;
}

/* ========== 数据卡片 ========== */
.data-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 12rpx;
  width: 100%;
}

.data-item {
  background: linear-gradient(135deg, rgba(102, 126, 234, 0.08) 0%, rgba(118, 75, 162, 0.08) 100%);
  border-radius: 14rpx;
  padding: 16rpx 12rpx;
  text-align: center;
  border: 1rpx solid rgba(102, 126, 234, 0.1);
  min-width: 0;
  overflow: hidden;
  word-break: break-word;
}

.data-label {
  display: block;
  font-size: 24rpx;
  color: #999999;
  margin-bottom: 10rpx;
  font-weight: 500;
}

.data-value {
  display: block;
  font-size: 28rpx;
  font-weight: 700;
  color: #667eea;
  line-height: 1;
}

/* ========== 结果卡片 ========== */
.result-card {
  margin-top: 8rpx;
}

.result-header {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.result-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  font-size: 32rpx;
  font-weight: 700;
  margin-right: 12rpx;
  color: white;
}

.fail-card .result-icon {
  background: linear-gradient(135deg, #ff4d4f 0%, #ff7875 100%);
}

.appeal-card .result-icon {
  background: linear-gradient(135deg, #409eff 0%, #667eea 100%);
}

.result-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333333;
}

.result-content {
  display: block;
  font-size: 26rpx;
  color: #666666;
  line-height: 1.6;
  margin: 12rpx 0;
  padding-left: 52rpx;
}

.result-reason {
  display: block;
  line-height: 1.6;
}

.appeal-button-wrapper {
  margin-top: 16rpx;
  display: flex;
  justify-content: center;
}

.appeal-button {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: white;
  border-radius: 16rpx;
  font-size: 28rpx;
  font-weight: 600;
  padding: 16rpx 48rpx;
  display: inline-block;
}

/* ========== 申诉详情卡片 ========== */
.appeal-detail-card {
  margin-top: 8rpx;
}

.appeal-status-row {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid rgba(0, 0, 0, 0.06);
}

.appeal-status-label {
  font-size: 24rpx;
  color: #999999;
  margin-right: 12rpx;
  font-weight: 500;
}

.appeal-status {
  padding: 8rpx 16rpx;
  border-radius: 16rpx;
  font-size: 24rpx;
  font-weight: 600;
}

.appeal-status.status-success {
  background: rgba(46, 125, 50, 0.1);
  border: 1rpx solid rgba(46, 125, 50, 0.3);
}

.appeal-status.status-success text {
  color: #2e7d32;
}

.appeal-status.status-failed {
  background: rgba(198, 40, 40, 0.1);
  border: 1rpx solid rgba(198, 40, 40, 0.3);
}

.appeal-status.status-failed text {
  color: #c62828;
}

.appeal-status.status-pending {
  background: rgba(239, 108, 0, 0.1);
  border: 1rpx solid rgba(239, 108, 0, 0.3);
}

.appeal-status.status-pending text {
  color: #ef6c00;
}

/* ========== 信息行 ========== */
.info-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid rgba(0, 0, 0, 0.04);
}

.info-label {
  font-size: 26rpx;
  color: #999999;
  font-weight: 500;
}

.info-value {
  font-size: 26rpx;
  color: #333333;
  text-align: right;
}

/* ========== 小节标题 ========== */
.section-subtitle {
  display: block;
  font-size: 26rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 12rpx;
  margin-top: 20rpx;
}

/* ========== 申诉理由部分 ========== */
.reason-section {
  margin-top: 16rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid rgba(0, 0, 0, 0.06);
}

.reason-text {
  display: block;
  font-size: 26rpx;
  color: #666666;
  line-height: 1.8;
  word-break: break-word;
}

/* ========== 证明材料 ========== */
.evidence-section {
  margin-top: 16rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid rgba(0, 0, 0, 0.06);
}

.evidence-container {
  margin-top: 12rpx;
}

.evidence-container.evidence-scrollable {
  margin-left: -20rpx;
  margin-right: -20rpx;
  padding-left: 20rpx;
  padding-right: 20rpx;
}

.evidence-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(160rpx, 1fr));
  gap: 16rpx;
  width: 100%;
}

.evidence-scroll {
  width: 100%;
  white-space: nowrap;
}

.evidence-scroll-content {
  display: inline-flex;
  gap: 16rpx;
  padding: 4rpx 0;
}

.evidence-thumbnail {
  position: relative;
  width: 160rpx;
  height: 160rpx;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.15);
  transition: all 0.3s ease;
  flex-shrink: 0;
}

.evidence-thumbnail:active {
  transform: scale(0.95);
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.2);
}

.evidence-thumbnail-image {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.evidence-thumbnail-overlay {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.4);
  display: flex;
  align-items: center;
  justify-content: center;
  opacity: 0;
  transition: opacity 0.3s ease;
  pointer-events: none; /* 允许点击事件穿透 */
}

.evidence-thumbnail:hover .evidence-thumbnail-overlay,
.evidence-thumbnail:active .evidence-thumbnail-overlay {
  opacity: 1;
}

.evidence-thumbnail-text {
  color: #ffffff;
  font-size: 22rpx;
  font-weight: 500;
  text-align: center;
}

.evidence-hint {
  margin-top: 12rpx;
  text-align: center;
}

.evidence-hint-text {
  font-size: 24rpx;
  color: #999999;
  font-style: italic;
}

/* ========== 审核结果 ========== */
.audit-section {
  margin-top: 16rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid rgba(0, 0, 0, 0.06);
}

.audit-text {
  display: block;
  font-size: 26rpx;
  color: #666666;
  line-height: 1.8;
  word-break: break-word;
}

/* ========== 模态框样式 ========== */
.modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 999;
}

.modal-content {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #ffffff;
  border-radius: 32rpx 32rpx 0 0;
  padding: 0;
  z-index: 1000;
  max-height: 80vh;
  overflow-y: auto;
  box-shadow: 0 -8rpx 32rpx rgba(0, 0, 0, 0.15);
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 28rpx 32rpx;
  border-bottom: 2rpx solid rgba(0, 0, 0, 0.1);
  background: #ffffff;
  position: sticky;
  top: 0;
  z-index: 10;
}

.modal-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #333333;
}

.modal-close {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: rgba(0, 0, 0, 0.08);
}

.close-text {
  font-size: 48rpx;
  color: #666666;
  line-height: 1;
}

.modal-body {
  padding: 32rpx;
  padding-bottom: 0;
}

.modal-desc {
  font-size: 24rpx;
  color: #666666;
  margin-bottom: 32rpx;
  line-height: 36rpx;
}

.form-item {
  margin-bottom: 32rpx;
}

.form-label {
  font-size: 28rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 12rpx;
  display: block;
}

.form-desc {
  font-size: 22rpx;
  color: #999999;
  margin-bottom: 20rpx;
  display: block;
}

.form-textarea {
  width: 100%;
  min-height: 180rpx;
  padding: 20rpx;
  border: 2rpx solid rgba(0, 0, 0, 0.1);
  border-radius: 16rpx;
  font-size: 26rpx;
  color: #333333;
  background: #ffffff;
  box-sizing: border-box;
}

.placeholder {
  color: #cccccc;
}

.count-text {
  font-size: 22rpx;
  color: #999999;
  text-align: right;
  margin-top: 8rpx;
  display: block;
}

.uploader-container {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
  margin-top: 16rpx;
}

.uploaded-image-item {
  position: relative;
  width: 200rpx;
  height: 200rpx;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.1);
}

.uploaded-image {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.image-delete {
  position: absolute;
  top: 8rpx;
  right: 8rpx;
  width: 40rpx;
  height: 40rpx;
  background: rgba(0, 0, 0, 0.6);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.delete-icon {
  width: 24rpx;
  height: 24rpx;
  filter: brightness(0) invert(1);
}

.upload-btn {
  width: 200rpx;
  height: 200rpx;
  border: 2rpx dashed rgba(0, 0, 0, 0.2);
  border-radius: 16rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: #ffffff;
}

.upload-text {
  font-size: 24rpx;
  color: #666666;
}

.modal-footer {
  display: flex;
  gap: 20rpx;
  padding: 24rpx 32rpx 40rpx;
  background: #ffffff;
  border-top: 2rpx solid rgba(0, 0, 0, 0.05);
  position: sticky;
  bottom: 0;
}

.modal-btn {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 700;
  padding: 24rpx 0;
  border-radius: 24rpx;
  border: none;
  text-align: center;
  box-sizing: border-box;
}

.cancel-btn {
  background: #f5f7fa;
  color: #666666;
}

.submit-btn {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #ffffff;
}

.submit-btn[disabled] {
  background: #cccccc;
  color: #ffffff;
  opacity: 0.6;
}

/* ========== 动画 ========== */
@keyframes slideUp {
  from {
    opacity: 0;
    transform: translateY(40rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

/* ========== 响应式设计 ========== */
@media (max-width: 375px) {
  .evidence-grid {
    grid-template-columns: repeat(2, auto);
    justify-content: center;
  }
  
  .uploaded-image-item, .upload-btn {
    width: 140rpx;
    height: 140rpx;
  }
  
  .modal-content {
    max-height: 90vh;
  }
}