/* pages/record-detail/record-detail.wxss */
.container {
  min-height: 100vh;
  background: linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%);
  padding: 20rpx;
  box-sizing: border-box;
}

.loading-container {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 200rpx 0;
}

.loading-spinner {
  width: 80rpx;
  height: 80rpx;
  border: 8rpx solid rgba(102, 126, 234, 0.2);
  border-top: 8rpx solid #667eea;
  border-radius: 50%;
  animation: spin 1s linear infinite;
  margin-bottom: 32rpx;
}

.loading-text {
  font-size: 28rpx;
  color: #666666;
}

@keyframes spin {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}

.detail-container {
  margin: 0 auto;
  max-width: 800rpx;
  width: 100%;
  box-sizing: border-box;
  animation: slideUp 0.6s cubic-bezier(0.34, 1.56, 0.64, 1) forwards;
}

.detail-section {
  background: rgba(255, 255, 255, 0.98);
  border-radius: 32rpx;
  box-shadow: 0 16rpx 50rpx rgba(0, 0, 0, 0.1), 0 8rpx 24rpx rgba(0, 0, 0, 0.06);
  padding: 40rpx;
  margin-bottom: 24rpx;
}

.section-header {
  margin-bottom: 24rpx;
  padding-bottom: 16rpx;
  border-bottom: 2rpx solid rgba(102, 126, 234, 0.1);
  position: relative;
}

.section-header::after {
  content: '';
  position: absolute;
  bottom: -2rpx;
  left: 0;
  width: 80rpx;
  height: 2rpx;
  background: linear-gradient(90deg, #667eea 0%, #764ba2 100%);
  border-radius: 1rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #333333;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  letter-spacing: 1rpx;
}

.section-content {
  padding: 0 8rpx;
}

.create-time {
  font-size: 32rpx;
  color: #333333;
  font-weight: 600;
  text-align: center;
}

.status-badge.large {
  font-size: 36rpx;
  padding: 20rpx 56rpx;
  border-radius: 40rpx;
  font-weight: 800;
  margin: 0 auto;
  color: #ffffff;
  display: block;
  text-align: center;
}

.status-passed.large {
  background: linear-gradient(135deg, #52c41a 0%, #73d13d 100%);
  box-shadow: 0 12rpx 40rpx rgba(82, 196, 26, 0.45);
}

.status-failed.large {
  background: linear-gradient(135deg, #ff4d4f 0%, #ff7875 100%);
  box-shadow: 0 12rpx 40rpx rgba(255, 77, 79, 0.45);
}

.status-pending.large {
  background: linear-gradient(135deg, #fa8c16 0%, #ffa940 100%);
  box-shadow: 0 12rpx 40rpx rgba(250, 140, 22, 0.45);
}

.fail-reason {
  background: #fff1f0;
  border: 2rpx solid rgba(245, 108, 108, 0.3);
  border-radius: 24rpx;
  padding: 28rpx;
  margin: 36rpx 0 0 0;
  box-shadow: 0 6rpx 24rpx rgba(0, 0, 0, 0.08);
}

.reason-label {
  font-size: 30rpx;
  font-weight: 700;
  color: #f56c6c;
  display: block;
  margin-bottom: 20rpx;
}

.reason-content {
  font-size: 28rpx;
  color: #666666;
  line-height: 44rpx;
  background: #ffffff;
  padding: 20rpx;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.08);
}

.data-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 28rpx;
  margin: 20rpx 0 0 0;
}

.data-item {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 40rpx 28rpx;
  box-shadow: 0 8rpx 28rpx rgba(0, 0, 0, 0.1);
  text-align: center;
  border: 1rpx solid rgba(0, 0, 0, 0.1);
  position: relative;
  overflow: hidden;
}

.data-item::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 4rpx;
  background: linear-gradient(90deg, #667eea 0%, #764ba2 100%);
}

.data-label {
  font-size: 28rpx;
  color: #666666;
  font-weight: 500;
  margin-bottom: 12rpx;
  display: block;
}

.data-value {
  display: block;
  font-size: 32rpx;
  font-weight: 800;
  color: #667eea;
  line-height: 1;
}

.images-container {
  display: flex;
  justify-content: center;
  align-items: center;
  margin-top: 20rpx;
}

.detail-image {
  width: 300rpx;
  height: 300rpx;
  border-radius: 20rpx;
  box-shadow: 0 12rpx 36rpx rgba(0, 0, 0, 0.15);
  object-fit: cover;
}

.appeal-section {
  margin-top: 40rpx;
  text-align: center;
  padding: 0 20rpx;
}

.appeal-btn {
  width: 100%;
  max-width: 500rpx;
  font-size: 32rpx;
  font-weight: 800;
  padding: 32rpx 0;
  border-radius: 36rpx;
  background: linear-gradient(135deg, #ff4d4f 0%, #ff7875 100%);
  color: #ffffff;
  box-shadow: 0 10rpx 32rpx rgba(255, 77, 79, 0.4);
  margin: 0 auto;
}

.modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.6);
  z-index: 999;
}

.modal-content {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #ffffff;
  border-radius: 32rpx 32rpx 0 0;
  padding: 0;
  z-index: 1000;
  max-height: 80vh;
  overflow-y: auto;
  box-shadow: 0 -8rpx 32rpx rgba(0, 0, 0, 0.15);
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 28rpx 32rpx;
  border-bottom: 2rpx solid rgba(0, 0, 0, 0.1);
  background: #ffffff;
  position: sticky;
  top: 0;
  z-index: 10;
}

.modal-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #333333;
}

.modal-close {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: rgba(0, 0, 0, 0.08);
}

.close-text {
  font-size: 48rpx;
  color: #666666;
  line-height: 1;
}

.modal-body {
  padding: 32rpx;
  padding-bottom: 0;
}

.modal-desc {
  font-size: 24rpx;
  color: #666666;
  margin-bottom: 32rpx;
  line-height: 36rpx;
}

.form-item {
  margin-bottom: 32rpx;
}

.form-label {
  font-size: 28rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 12rpx;
  display: block;
}

.form-desc {
  font-size: 22rpx;
  color: #999999;
  margin-bottom: 20rpx;
  display: block;
}

.form-textarea {
  width: 100%;
  min-height: 180rpx;
  padding: 20rpx;
  border: 2rpx solid rgba(0, 0, 0, 0.1);
  border-radius: 16rpx;
  font-size: 26rpx;
  color: #333333;
  background: #ffffff;
  box-sizing: border-box;
}

.placeholder {
  color: #cccccc;
}

.count-text {
  font-size: 22rpx;
  color: #999999;
  text-align: right;
  margin-top: 8rpx;
  display: block;
}

.uploader-container {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
  margin-top: 16rpx;
}

.uploaded-image-item {
  position: relative;
  width: 200rpx;
  height: 200rpx;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.1);
}

.uploaded-image {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.image-delete {
  position: absolute;
  top: 8rpx;
  right: 8rpx;
  width: 40rpx;
  height: 40rpx;
  background: rgba(0, 0, 0, 0.6);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.delete-icon {
  width: 24rpx;
  height: 24rpx;
  filter: brightness(0) invert(1);
}

.upload-btn {
  width: 200rpx;
  height: 200rpx;
  border: 2rpx dashed rgba(0, 0, 0, 0.2);
  border-radius: 16rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: #ffffff;
}

.upload-icon {
  width: 60rpx;
  height: 60rpx;
  margin-bottom: 12rpx;
  opacity: 0.6;
}

.upload-text {
  font-size: 24rpx;
  color: #666666;
}

.modal-footer {
  display: flex;
  gap: 20rpx;
  padding: 24rpx 32rpx 40rpx;
  background: #ffffff;
  border-top: 2rpx solid rgba(0, 0, 0, 0.05);
  position: sticky;
  bottom: 0;
}

.modal-btn {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 700;
  padding: 24rpx 0;
  border-radius: 24rpx;
  border: none;
  text-align: center;
  box-sizing: border-box;
}

.cancel-btn {
  background: #f5f7fa;
  color: #666666;
}

.submit-btn {
  background: linear-gradient(135deg, #f56c6c 0%, #f78989 100%);
  color: #ffffff;
}

.submit-btn[disabled] {
  background: #cccccc;
  color: #ffffff;
  opacity: 0.6;
}

@keyframes fadeIn {
  from {
    opacity: 0;
    transform: translateY(20rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

@keyframes slideUp {
  from {
    opacity: 0;
    transform: translateY(40rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

@keyframes slideUpModal {
  from {
    transform: translateY(100%);
  }
  to {
    transform: translateY(0);
  }
}

@media (max-width: 375px) {
  .data-grid {
    grid-template-columns: 1fr;
  }
  
  .detail-image {
    width: 240rpx;
    height: 240rpx;
  }
  
  .uploaded-image-item, .upload-btn {
    width: 140rpx;
    height: 140rpx;
  }
  
  .modal-footer {
    flex-direction: column;
  }
  
  .modal-content {
    max-height: 90vh;
  }
}