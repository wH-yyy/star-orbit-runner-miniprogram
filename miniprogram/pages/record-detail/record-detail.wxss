/* pages/record-detail/record-detail.wxss */
.container {
  min-height: 100vh;
  background: linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%);
  padding: 20rpx;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
}

/* 顶部导航栏 */
.nav-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 0;
  margin-bottom: 30rpx;
  animation: fadeIn 0.4s ease forwards;
}

.nav-left {
  flex: 1;
}

.nav-title {
  flex: 2;
  text-align: center;
}

.nav-right {
  flex: 1;
}

.back-btn {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 12rpx 20rpx;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.9);
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.1);
  transition: all 0.3s ease;
}

.back-btn:hover {
  transform: translateX(-4rpx);
  box-shadow: 0 6rpx 20rpx rgba(102, 126, 234, 0.2);
  background: rgba(102, 126, 234, 0.1);
}

.back-icon {
  font-size: 36rpx;
  font-weight: 600;
  color: #666666;
  line-height: 1;
}

.back-text {
  font-size: 28rpx;
  font-weight: 600;
  color: #333333;
}

.title {
  font-size: 40rpx;
  font-weight: 800;
  color: #333333;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  margin-bottom: 8rpx;
  display: block;
  animation: fadeIn 0.6s ease forwards;
  letter-spacing: -1rpx;
  text-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.08);
}

.subtitle {
  font-size: 24rpx;
  color: #666666;
  animation: fadeIn 0.6s ease 0.2s forwards;
  opacity: 0;
  display: block;
  font-weight: 500;
}

/* 加载状态 */
.loading-container {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 200rpx 0;
}

.loading-spinner {
  width: 80rpx;
  height: 80rpx;
  border: 8rpx solid rgba(102, 126, 234, 0.2);
  border-top: 8rpx solid #667eea;
  border-radius: 50%;
  animation: spin 1s linear infinite;
  margin-bottom: 32rpx;
}

.loading-text {
  font-size: 28rpx;
  color: #666666;
  animation: pulse 1.5s ease-in-out infinite;
}

@keyframes spin {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}

/* 详情卡片 */
.detail-card {
  margin: 0 auto;
  background: rgba(255, 255, 255, 0.98);
  border-radius: 32rpx;
  box-shadow: 0 16rpx 50rpx rgba(0, 0, 0, 0.1), 0 8rpx 24rpx rgba(0, 0, 0, 0.06);
  backdrop-filter: blur(30rpx);
  border: 1rpx solid rgba(255, 255, 255, 0.8);
  overflow: hidden;
  animation: slideUp 0.6s cubic-bezier(0.34, 1.56, 0.64, 1) forwards;
  padding: 40rpx;
  max-width: 800rpx;
  width: 100%;
  box-sizing: border-box;
}

/* 状态标识 */
.status-badge {
  font-size: 24rpx;
  font-weight: 600;
  padding: 10rpx 24rpx;
  border-radius: 24rpx;
  color: #ffffff;
  display: block;
  text-align: center;
  transition: all 0.4s ease;
  margin: 0 auto 40rpx;
  animation: pulse 2s ease-in-out infinite;
}

.status-badge.large {
  font-size: 36rpx;
  padding: 20rpx 56rpx;
  border-radius: 40rpx;
  font-weight: 800;
  margin: 0 auto 48rpx;
  letter-spacing: 1rpx;
}

.status-passed {
  background: linear-gradient(135deg, #67c23a 0%, #85ce61 100%);
  box-shadow: 0 8rpx 28rpx rgba(103, 194, 58, 0.4);
}

.status-passed.large {
  background: linear-gradient(135deg, #52c41a 0%, #73d13d 100%);
  box-shadow: 0 12rpx 40rpx rgba(82, 196, 26, 0.45);
}

.status-failed {
  background: linear-gradient(135deg, #f56c6c 0%, #f78989 100%);
  box-shadow: 0 8rpx 28rpx rgba(245, 108, 108, 0.4);
}

.status-failed.large {
  background: linear-gradient(135deg, #ff4d4f 0%, #ff7875 100%);
  box-shadow: 0 12rpx 40rpx rgba(255, 77, 79, 0.45);
}

.status-pending {
  background: linear-gradient(135deg, #e6a23c 0%, #ebb563 100%);
  box-shadow: 0 8rpx 28rpx rgba(230, 162, 60, 0.4);
}

.status-pending.large {
  background: linear-gradient(135deg, #fa8c16 0%, #ffa940 100%);
  box-shadow: 0 12rpx 40rpx rgba(250, 140, 22, 0.45);
}

/* 信息项 */
.info-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 28rpx 36rpx;
  border-bottom: 2rpx solid rgba(0, 0, 0, 0.08);
  background: linear-gradient(135deg, #ffffff 0%, #f8f9fa 100%);
  margin: 0 -40rpx;
  transition: all 0.3s ease;
}

.info-item:first-of-type {
  margin-top: -40rpx;
  border-top-left-radius: 32rpx;
  border-top-right-radius: 32rpx;
  background: linear-gradient(135deg, #f0f5ff 0%, #e6f0ff 100%);
}

.info-item:last-child {
  border-bottom: none;
  background: linear-gradient(135deg, #f0f5ff 0%, #e6f0ff 100%);
}

.info-item:hover {
  background: linear-gradient(135deg, #e3f2fd 0%, #bbdefb 100%);
}

.info-label {
  font-size: 30rpx;
  color: #666666;
  font-weight: 600;
}

.info-value {
  font-size: 30rpx;
  color: #333333;
  font-weight: 700;
  text-align: right;
}

/* 打卡方式值 */
.type-value {
  color: #667eea;
  background: rgba(102, 126, 234, 0.2);
  padding: 12rpx 28rpx;
  border-radius: 28rpx;
  font-weight: 600;
  font-size: 28rpx;
  box-shadow: 0 4rpx 16rpx rgba(102, 126, 234, 0.15);
}

/* 不通过原因 */
.fail-reason {
  background: linear-gradient(135deg, #fff1f0 0%, #ffecec 100%);
  border: 2rpx solid rgba(245, 108, 108, 0.3);
  border-radius: 24rpx;
  padding: 28rpx;
  margin: 36rpx 0;
  animation: fadeIn 0.5s ease forwards;
  box-shadow: 0 6rpx 24rpx rgba(0, 0, 0, 0.08);
}

.reason-label {
  font-size: 30rpx;
  font-weight: 700;
  color: #f56c6c;
  display: block;
  margin-bottom: 20rpx;
  background: linear-gradient(135deg, #f56c6c 0%, #f78989 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.reason-content {
  font-size: 28rpx;
  color: #666666;
  line-height: 44rpx;
  background: #ffffff;
  padding: 20rpx;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.08);
  border: 1rpx solid rgba(0, 0, 0, 0.05);
}

/* 数据网格 */
.data-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 28rpx;
  margin: 40rpx 0;
}

.data-item {
  background: linear-gradient(135deg, #ffffff 0%, #f8f9fa 100%);
  border-radius: 24rpx;
  padding: 40rpx 28rpx;
  box-shadow: 0 8rpx 28rpx rgba(0, 0, 0, 0.1), 0 4rpx 12rpx rgba(0, 0, 0, 0.06);
  text-align: center;
  transition: all 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
  border: 1rpx solid rgba(0, 0, 0, 0.1);
  position: relative;
  overflow: hidden;
}

.data-item::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 4rpx;
  background: linear-gradient(90deg, #667eea 0%, #764ba2 100%);
  transform: scaleX(0);
  transition: transform 0.3s ease;
}

.data-item:hover::before {
  transform: scaleX(1);
}

.data-item:hover {
  transform: translateY(-10rpx);
  box-shadow: 0 20rpx 56rpx rgba(102, 126, 234, 0.25), 0 12rpx 36rpx rgba(102, 126, 234, 0.18);
  border-color: rgba(102, 126, 234, 0.5);
}

.data-value {
  display: block;
  font-size: 56rpx;
  font-weight: 800;
  color: #667eea;
  margin-bottom: 16rpx;
  line-height: 1;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  letter-spacing: -2rpx;
  animation: fadeIn 0.6s ease forwards;
}

.data-label {
  font-size: 28rpx;
  color: #666666;
  font-weight: 500;
  animation: fadeIn 0.6s ease 0.2s forwards;
  opacity: 0;
}

/* 地图占位符 */
.map-placeholder {
  position: relative;
  width: 100%;
  height: 360rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
  box-shadow: 0 12rpx 36rpx rgba(102, 126, 234, 0.3);
  transition: all 0.3s ease;
  margin: 36rpx 0;
}

.map-image {
  width: 100%;
  height: 100%;
  opacity: 0.4;
  transition: opacity 0.3s ease;
}

.map-placeholder:hover .map-image {
  opacity: 0.5;
}

.map-text {
  position: absolute;
  font-size: 36rpx;
  font-weight: 700;
  color: #ffffff;
  text-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.4);
  letter-spacing: 2rpx;
  animation: pulse 2s ease-in-out infinite;
  background: rgba(0, 0, 0, 0.2);
  padding: 12rpx 32rpx;
  border-radius: 24rpx;
}

/* 手动打卡图片 */
.manual-images {
  margin: 36rpx 0;
}

.images-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #333333;
  display: block;
  margin-bottom: 20rpx;
}

.images-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(220rpx, 1fr));
  gap: 20rpx;
}

.image-item {
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.08);
  transition: all 0.3s ease;
}

.image-item:hover {
  transform: translateY(-4rpx);
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.12);
}

.manual-image {
  width: 100%;
  height: 220rpx;
  object-fit: cover;
  transition: all 0.3s ease;
}

.manual-image:hover {
  transform: scale(1.05);
}

/* 申诉按钮 */
.appeal-btn {
  width: 100%;
  max-width: 500rpx;
  font-size: 32rpx;
  font-weight: 800;
  padding: 32rpx 0;
  border-radius: 36rpx;
  border: none;
  transition: all 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
  background: linear-gradient(135deg, #ff4d4f 0%, #ff7875 100%);
  color: #ffffff !important;
  text-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.3);
  box-shadow: 0 10rpx 32rpx rgba(255, 77, 79, 0.4);
  margin: 32rpx auto 0;
  box-sizing: border-box;
  text-align: center;
  line-height: normal;
}

.appeal-btn::after {
  border: none;
  border-radius: 36rpx;
}

.appeal-btn:hover {
  transform: translateY(-8rpx);
  box-shadow: 0 16rpx 48rpx rgba(255, 77, 79, 0.5);
  background: linear-gradient(135deg, #ff3b30 0%, #ff6b6b 100%);
}

.appeal-btn:active {
  transform: translateY(-4rpx);
}

/* 模态框样式 */
.modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.6);
  z-index: 999;
  animation: fadeIn 0.3s ease forwards;
}

.modal-content {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #ffffff;
  border-radius: 32rpx 32rpx 0 0;
  padding: 0;
  z-index: 1000;
  animation: slideUpModal 0.3s cubic-bezier(0.34, 1.56, 0.64, 1) forwards;
  max-height: 80vh;
  overflow-y: auto;
  box-shadow: 0 -8rpx 32rpx rgba(0, 0, 0, 0.15);
}

/* 模态框头部 */
.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 28rpx 32rpx;
  border-bottom: 2rpx solid rgba(0, 0, 0, 0.1);
  background: rgba(255, 255, 255, 0.95);
  position: sticky;
  top: 0;
  z-index: 10;
}

.modal-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #333333;
}

.modal-close {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: rgba(0, 0, 0, 0.08);
  transition: all 0.3s ease;
  cursor: pointer;
}

.modal-close:hover {
  background: rgba(245, 108, 108, 0.15);
  transform: rotate(90deg);
}

.close-text {
  font-size: 48rpx;
  font-weight: 300;
  color: #666666;
  line-height: 1;
  transform: rotate(0deg);
  transition: all 0.3s ease;
}

.modal-close:hover .close-text {
  color: #f56c6c;
  transform: rotate(90deg);
}

/* 模态框内容 */
.modal-body {
  padding: 32rpx;
  padding-bottom: 0;
}

.modal-desc {
  font-size: 24rpx;
  color: #666666;
  margin-bottom: 32rpx;
  display: block;
  line-height: 36rpx;
}

/* 表单项样式 */
.form-item {
  margin-bottom: 32rpx;
}

.form-item:last-child {
  margin-bottom: 0;
}

.form-label {
  font-size: 28rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 12rpx;
  display: block;
}

.form-desc {
  font-size: 22rpx;
  color: #999999;
  margin-bottom: 20rpx;
  display: block;
}

/* 文本域样式 */
.form-textarea {
  width: 100%;
  min-height: 180rpx;
  padding: 20rpx;
  border: 2rpx solid rgba(0, 0, 0, 0.1);
  border-radius: 16rpx;
  font-size: 26rpx;
  color: #333333;
  background: rgba(255, 255, 255, 0.9);
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
  resize: none;
  box-sizing: border-box;
  transition: all 0.3s ease;
}

.form-textarea:focus {
  border-color: #667eea;
  box-shadow: 0 4rpx 16rpx rgba(102, 126, 234, 0.15);
  outline: none;
}

.placeholder {
  color: #cccccc;
}

.count-text {
  font-size: 22rpx;
  color: #999999;
  text-align: right;
  margin-top: 8rpx;
  display: block;
}

/* 图片上传样式 */
.uploader-container {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
  margin-top: 16rpx;
}

.uploaded-image-item {
  position: relative;
  width: 200rpx;
  height: 200rpx;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.1);
}

.uploaded-image {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.image-delete {
  position: absolute;
  top: 8rpx;
  right: 8rpx;
  width: 40rpx;
  height: 40rpx;
  background: rgba(0, 0, 0, 0.6);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.3s ease;
  cursor: pointer;
}

.image-delete:hover {
  background: rgba(245, 108, 108, 0.8);
  transform: scale(1.1);
}

.delete-icon {
  width: 24rpx;
  height: 24rpx;
  filter: brightness(0) invert(1);
}

.upload-btn {
  width: 200rpx;
  height: 200rpx;
  border: 2rpx dashed rgba(0, 0, 0, 0.2);
  border-radius: 16rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.9);
  transition: all 0.3s ease;
  cursor: pointer;
}

.upload-btn:hover {
  border-color: #667eea;
  background: rgba(102, 126, 234, 0.05);
  transform: translateY(-2rpx);
}

.upload-icon {
  width: 60rpx;
  height: 60rpx;
  margin-bottom: 12rpx;
  opacity: 0.6;
}

.upload-text {
  font-size: 24rpx;
  color: #666666;
}

/* 模态框底部按钮 */
.modal-footer {
  display: flex;
  gap: 20rpx;
  padding: 24rpx 32rpx 40rpx;
  background: #ffffff;
  border-top: 2rpx solid rgba(0, 0, 0, 0.05);
  position: sticky;
  bottom: 0;
}

.modal-btn {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  font-size: 28rpx;
  font-weight: 700;
  padding: 24rpx 0;
  border-radius: 24rpx;
  border: none;
  transition: all 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
  text-align: center;
  box-sizing: border-box;
}

.modal-btn::after {
  border: none;
}

.modal-btn text {
  color: inherit;
  font-weight: 700;
  line-height: 1;
  display: inline-block;
  vertical-align: middle;
}

.cancel-btn {
  background: linear-gradient(135deg, #f5f7fa 0%, #e9ecef 100%);
  color: #666666;
}

.cancel-btn:hover {
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.15);
}

.submit-btn {
  background: linear-gradient(135deg, #f56c6c 0%, #f78989 100%);
  color: #ffffff !important;
  font-weight: 700;
  text-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.3);
}

.submit-btn text {
  color: #ffffff !important;
  font-weight: 700;
  line-height: 1;
}

.submit-btn:hover:not([disabled]) {
  box-shadow: 0 12rpx 36rpx rgba(245, 108, 108, 0.4);
}

.submit-btn[disabled] {
  background: linear-gradient(135deg, #cccccc 0%, #999999 100%);
  color: #ffffff !important;
  opacity: 0.6;
  cursor: not-allowed;
}

.submit-btn[disabled] text {
  color: #ffffff !important;
  opacity: 0.8;
}

.submit-btn[disabled]:hover {
  transform: none;
  box-shadow: none;
}

/* 动画效果 */
@keyframes fadeIn {
  from {
    opacity: 0;
    transform: translateY(20rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

@keyframes slideUp {
  from {
    opacity: 0;
    transform: translateY(40rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

@keyframes pulse {
  0%, 100% {
    opacity: 1;
    transform: scale(1);
  }
  50% {
    opacity: 0.8;
    transform: scale(1.05);
  }
}

@keyframes slideUpModal {
  from {
    transform: translateY(100%);
  }
  to {
    transform: translateY(0);
  }
}

/* 响应式设计 */
@media (max-width: 375px) {
  .data-grid {
    grid-template-columns: 1fr;
  }
  
  .info-item {
    flex-direction: column;
    align-items: flex-start;
    gap: 8rpx;
  }
  
  .info-value {
    text-align: left;
  }
  
  .uploaded-image-item, .upload-btn {
    width: 140rpx;
    height: 140rpx;
  }
  
  .modal-footer {
    flex-direction: column;
  }
  
  .modal-content {
    max-height: 90vh;
  }
}
