<view class="container">
  <!-- 加载状态 -->
  <view wx:if="{{loading}}" class="loading-container">
    <view class="loading-spinner"></view>
    <text class="loading-text">加载记录详情中...</text>
  </view>

  <!-- 记录详情 -->
  <view wx:else class="detail-container">

    <!-- 第一部分：打卡时间 -->
    <view class="detail-section">
      <view class="section-header">
        <text class="section-title">打卡时间</text>
      </view>
      <view class="section-content">
        <text class="create-time">{{record.create_date}}-{{record.create_time_24}}</text>
      </view>
    </view>

    <!-- 第二部分：审核状态 -->
    <view class="detail-section">
      <view class="section-header">
        <text class="section-title">审核状态</text>
      </view>
      <view class="section-content">
        <view
          class="status-badge large {{record.status === 1 ? 'status-passed' : record.status === 0 ? 'status-pending' : record.status === 2 ? 'status-failed' : 'status-appeal'}}">
          {{record.status === 1 ? '已通过' : record.status === 0 ? '待审核' : record.status === 2 ? '不通过' : '申诉中'}}
        </view>

        <!-- 不通过原因 -->
        <view wx:if="{{record.status === 2 && record.audit_reason}}" class="fail-reason">
          {{record.audit_reason}}
        </view>

        <!-- 申诉状态说明 -->
        <view wx:if="{{record.status === 3}}" class="appeal-info">
          <text class="appeal-label">申诉说明：</text>
          <text class="appeal-content">已提交申诉，请等待管理员审核</text>
        </view>
      </view>
    </view>

    <!-- 第三部分：识别的跑步数据 -->
    <view class="detail-section">
      <view class="section-header">
        <text class="section-title">识别的跑步数据</text>
      </view>
      <view class="section-content">
        <view class="data-grid">
          <view class="data-item">
            <text class="data-label">跑步时间</text>
            <text class="data-value">{{record.running_date || '--'}}</text>
          </view>
          <view class="data-item">
            <text class="data-label">跑步距离</text>
            <text class="data-value">{{record.running_distance || '0'}} km</text>
          </view>
          <view class="data-item">
            <text class="data-label">跑步时长</text>
            <text class="data-value">{{record.running_duration || '0'}}</text>
          </view>
          <view class="data-item">
            <text class="data-label">配速</text>
            <text class="data-value">{{record.running_pace || '0'}}</text>
          </view>
        </view>
      </view>
    </view>

    <!-- 第四部分：打卡图片 -->
    <view wx:if="{{record.imageFileID}}" class="detail-section">
      <view class="section-header">
        <text class="section-title">打卡图片</text>
      </view>
      <view class="section-content">
        <view class="images-container">
          <image src="{{record.imageFileID}}" class="detail-image" mode="aspectFill" bindtap="previewImage"
            data-index="0"></image>
        </view>
      </view>
    </view>

    <!-- 申诉按钮，仅不通过记录（状态2）显示，申诉中（状态3）不显示 -->
    <view wx:if="{{record.status === 2}}" class="appeal-section">
      <button class="appeal-btn" bindtap="showAppealModal">提交申诉</button>
    </view>
  </view>

  <!-- 申诉模态框 -->
  <view wx:if="{{showAppealModal}}" class="modal-overlay" bindtap="hideAppealModal"></view>
  <view wx:if="{{showAppealModal}}" class="modal-content" catchtap="">
    <!-- 模态框头部 -->
    <view class="modal-header">
      <text class="modal-title">申诉申请</text>
      <view class="modal-close" bindtap="hideAppealModal">
        <text class="close-text">×</text>
      </view>
    </view>

    <!-- 模态框内容 -->
    <view class="modal-body">
      <text class="modal-desc">请说明您的申诉理由，并上传相关证明材料</text>

      <!-- 申诉理由输入 -->
      <view class="form-item">
        <text class="form-label">申诉理由</text>
        <textarea class="form-textarea" placeholder="请详细说明您的申诉理由..." placeholder-class="placeholder"
          bindinput="onAppealReasonInput" value="{{appealReason}}" maxlength="500" auto-height
          show-confirm-bar></textarea>
        <text class="count-text">{{appealReason.length}}/500</text>
      </view>

      <!-- 图片上传 -->
      <view class="form-item">
        <text class="form-label">上传证明材料</text>
        <text class="form-desc">最多可上传5张图片，支持jpg、png格式</text>
        <view class="uploader-container">
          <!-- 已上传图片 -->
          <view wx:for="{{uploadedImages}}" wx:key="index" class="uploaded-image-item">
            <image src="{{item}}" class="uploaded-image" mode="aspectFit"></image>
            <view class="image-delete" bindtap="deleteImage" data-index="{{index}}">
              <image src="/images/delete.png" class="delete-icon" mode="aspectFit"></image>
            </view>
          </view>

          <!-- 上传按钮 -->
          <view wx:if="{{uploadedImages.length < 5}}" class="upload-btn" bindtap="uploadImage">
            <text class="upload-text">+ 上传图片</text>
          </view>
        </view>
      </view>
    </view>

    <!-- 模态框底部按钮 -->
    <view class="modal-footer">
      <button class="modal-btn cancel-btn" type="default" bindtap="cancelAppeal">
        <text>取消</text>
      </button>
      <button class="modal-btn submit-btn" bindtap="submitAppeal" disabled="{{!appealReason}}">
        <text>提交申诉</text>
      </button>
    </view>
  </view>
</view>