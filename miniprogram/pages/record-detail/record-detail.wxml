<view class="container">
  <!-- 加载状态 -->
  <view wx:if="{{loading}}" class="loading-container">
    <view class="loading-spinner"></view>
    <text class="loading-text">加载记录详情中...</text>
  </view>

  <!-- 记录详情 -->
  <view wx:else class="detail-container">

    <!-- 第一部分：头部卡片 - 打卡时间和状态 -->
    <view class="header-card">
      <view class="time-status-row">
        <view class="time-info">
          <text class="time-label">打卡时间</text>
          <text class="time-value">{{record.create_date}} {{record.create_time_24}}</text>
        </view>
        <view class="status-indicator {{record.status === 1 ? 'status-passed' : record.status === 0 ? 'status-pending' : record.status === 2 ? 'status-failed' : 'status-appeal'}}">
          <text class="status-text">{{record.status === 1 ? '已通过' : record.status === 0 ? '待审核' : record.status === 2 ? '不通过' : '申诉中'}}</text>
        </view>
      </view>
    </view>

    <!-- 打卡图片 -->
    <view wx:if="{{record.imageFileID}}" class="image-container">
      <text class="detail-image-title">跑步截图</text>
      <image src="{{record.imageFileID}}" class="detail-image" mode="widthFix"></image>
    </view>

    <!-- 步数截图 -->
    <view wx:if="{{record.stepImageFileID}}" class="image-container">
      <text class="step-image-title">步数截图</text>
      <image src="{{record.stepImageFileID}}" class="step-image" mode="widthFix"></image>
    </view>

    <!-- 审核结果区域 -->
    <view wx:if="{{record.status === 2}}" class="result-card fail-card">
      <view class="result-header">
        <text class="result-icon">!</text>
        <text class="result-title">审核未通过</text>
      </view>
      <view wx:if="{{record.audit_reason}}" class="result-content">
        <text class="result-reason">{{record.audit_reason}}</text>
      </view>
      <view wx:if="{{!appeal}}" class="appeal-button-wrapper">
        <button class="appeal-button" bindtap="showAppealModal">提交申诉</button>
      </view>
    </view>

    <view wx:elif="{{record.status === 3}}" class="result-card appeal-card">
      <view class="result-header">
        <text class="result-icon">⋯</text>
        <text class="result-title">申诉中</text>
      </view>
      <text class="result-content">已提交申诉，请等待管理员审核</text>
    </view>

    <!-- 申诉详情卡片 -->
    <view wx:if="{{appeal}}" class="appeal-detail-card">
      <text class="card-title">申诉详情</text>
      
      <!-- 申诉状态指示 -->
      <view class="appeal-status-row">
        <text class="appeal-status-label">状态：</text>
        <view class="appeal-status {{appeal.statusClass}}">
          <text>{{appeal.statusText}}</text>
        </view>
      </view>

      <!-- 申诉时间 -->
      <view class="info-row">
        <text class="info-label">申诉时间</text>
        <text class="info-value">{{appeal.formattedCreateTime}}</text>
      </view>

      <!-- 审核时间 -->
      <view wx:if="{{appeal.status !== 0 && appeal.formattedAuditTime}}" class="info-row">
        <text class="info-label">审核时间</text>
        <text class="info-value">{{appeal.formattedAuditTime}}</text>
      </view>

      <!-- 申诉理由 -->
      <view class="reason-section">
        <text class="section-subtitle">申诉理由</text>
        <text class="reason-text">{{appeal.appealReason}}</text>
      </view>

      <!-- 证明材料 -->
      <view wx:if="{{appeal.appealImages && appeal.appealImages.length > 0}}" class="evidence-section">
        <text class="section-subtitle">证明材料</text>
        <view class="evidence-container {{appeal.appealImages.length > 3 ? 'evidence-scrollable' : ''}}">
          <scroll-view wx:if="{{appeal.appealImages.length > 3}}" class="evidence-scroll" scroll-x="true" enhanced="true" show-scrollbar="false">
            <view class="evidence-scroll-content">
              <view wx:for="{{appeal.appealImages}}" wx:key="index" class="evidence-thumbnail" bindtap="previewAppealImage" data-index="{{index}}">
                <image src="{{item}}" class="evidence-thumbnail-image" mode="aspectFill"></image>
                <view class="evidence-thumbnail-overlay">
                  <text class="evidence-thumbnail-text">查看大图</text>
                </view>
              </view>
            </view>
          </scroll-view>
          <view wx:else class="evidence-grid">
            <view wx:for="{{appeal.appealImages}}" wx:key="index" class="evidence-thumbnail" bindtap="previewAppealImage" data-index="{{index}}">
              <image src="{{item}}" class="evidence-thumbnail-image" mode="aspectFill"></image>
              <view class="evidence-thumbnail-overlay">
                <text class="evidence-thumbnail-text">查看大图</text>
              </view>
            </view>
          </view>
        </view>
        <view wx:if="{{appeal.appealImages.length > 4}}" class="evidence-hint">
          <text class="evidence-hint-text">左右滑动查看更多图片</text>
        </view>
      </view>

      <!-- 审核结果 -->
      <view wx:if="{{appeal.status !== 0 && appeal.auditResult}}" class="audit-section">
        <text class="section-subtitle">审核结果</text>
        <text class="audit-text">{{appeal.auditResult}}</text>
      </view>
    </view>
  </view>

  <!-- 申诉模态框 -->
  <view wx:if="{{showAppealModal}}" class="modal-overlay" bindtap="hideAppealModal"></view>
  <view wx:if="{{showAppealModal}}" class="modal-content" catchtap="">
    <!-- 模态框头部 -->
    <view class="modal-header">
      <text class="modal-title">申诉申请</text>
      <view class="modal-close" bindtap="hideAppealModal">
        <text class="close-text">×</text>
      </view>
    </view>

    <!-- 模态框内容 -->
    <view class="modal-body">
      <text class="modal-desc">请说明您的申诉理由，并上传相关证明材料</text>

      <!-- 申诉理由输入 -->
      <view class="form-item">
        <text class="form-label">申诉理由</text>
        <textarea class="form-textarea" placeholder="请详细说明您的申诉理由..." placeholder-class="placeholder"
          bindinput="onAppealReasonInput" value="{{appealReason}}" maxlength="500" auto-height
          show-confirm-bar></textarea>
        <text class="count-text">{{appealReason.length}}/500</text>
      </view>

      <!-- 图片上传 -->
      <view class="form-item">
        <text class="form-label">上传证明材料</text>
        <text class="form-desc">最多可上传5张图片</text>
        <view class="uploader-container">
          <!-- 已上传图片 -->
          <view wx:for="{{uploadedImages}}" wx:key="index" class="uploaded-image-item">
            <image src="{{item}}" class="uploaded-image" mode="aspectFit"></image>
            <view class="image-delete" bindtap="deleteImage" data-index="{{index}}">
              <image src="/images/delete.png" class="delete-icon" mode="aspectFit"></image>
            </view>
          </view>

          <!-- 上传按钮 -->
          <view wx:if="{{uploadedImages.length < 5}}" class="upload-btn" bindtap="uploadImage">
            <text class="upload-text">+ 上传图片</text>
          </view>
        </view>
      </view>
    </view>

    <!-- 模态框底部按钮 -->
    <view class="modal-footer">
      <button class="modal-btn cancel-btn" type="default" bindtap="hideAppealModal">
        <text>取消</text>
      </button>
      <button class="modal-btn submit-btn" bindtap="submitAppeal" disabled="{{!appealReason}}">
        <text>提交申诉</text>
      </button>
    </view>
  </view>
</view>