/* pages/submit/submit.wxss */
.container {
  min-height: 100vh;
  background: linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%);
  padding: 40rpx 30rpx;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.title {
  font-size: 44rpx;
  font-weight: 700;
  color: #333333;
  letter-spacing: 2rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  margin-bottom: 40rpx;
  text-align: center;
  width: 100%;
  animation: fadeIn 0.6s ease forwards;
}

.form-item {
  width: 100%;
  max-width: 600rpx;
  margin-bottom: 40rpx;
  animation: fadeIn 0.6s ease forwards;
  opacity: 0;
}

.form-item:nth-child(1) {
  animation-delay: 0.1s;
}

.form-item:nth-child(2) {
  animation-delay: 0.2s;
}

.form-item:nth-child(3) {
  animation-delay: 0.3s;
}

@keyframes fadeIn {
  from {
    opacity: 0;
    transform: translateY(20rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.label {
  display: block;
  font-size: 32rpx;
  font-weight: 600;
  color: #444444;
  margin-bottom: 16rpx;
  letter-spacing: 1rpx;
}

.input {
  width: 100%;
  height: 96rpx;
  border: 3rpx solid #e0e0e0;
  border-radius: 24rpx;
  padding: 0 30rpx;
  box-sizing: border-box;
  font-size: 32rpx;
  color: #333333;
  background: rgba(255, 255, 255, 0.9);
  transition: all 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.input:focus {
  border-color: #667eea;
  box-shadow: 0 8rpx 24rpx rgba(102, 126, 234, 0.2), inset 0 0 0 3rpx rgba(102, 126, 234, 0.1);
  transform: translateY(-2rpx);
  background: rgba(255, 255, 255, 0.95);
}

.schedule-container {
  width: 100%;
  border: 3rpx solid #e0e0e0;
  border-radius: 24rpx;
  box-sizing: border-box;
  font-size: 32rpx;
  background: rgba(255, 255, 255, 0.9);
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  letter-spacing: 2rpx;
  font-weight: 500;
  cursor: default;
  user-select: none;
  background: linear-gradient(135deg, rgba(255,255,255,0.9) 0%, rgba(245,247,250,0.9) 100%);
  color: #667eea;
  min-height: 200rpx;
  padding: 30rpx 0;
}

.academic-term,
.date-range,
.time-range {
  line-height: 1.5;
  width: 100%;
  text-align: center;
}

.academic-term {
  font-size: 32rpx;
  font-weight: 500;
  color: #6976eb;
}

.date-range {
  font-size: 32rpx;
  font-weight: 600;
  color: #5a67d8;
}

.time-range {
  font-size: 34rpx;
  font-weight: 600;
  color: #5a67d8;
}

.picker {
  width: 100%;
  height: 96rpx;
  border: 3rpx solid #e0e0e0;
  border-radius: 24rpx;
  padding: 0 30rpx;
  box-sizing: border-box;
  background: rgba(255, 255, 255, 0.9);
  transition: all 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
  display: flex;
  align-items: center;
  cursor: pointer;
}

.picker:hover {
  border-color: #667eea;
  box-shadow: 0 4rpx 16rpx rgba(102, 126, 234, 0.15);
  transform: translateY(-2rpx);
}

.picker-content {
  font-size: 32rpx;
  color: #333333;
  display: flex;
  align-items: center;
  width: 100%;
}

.picker-content::before {
  content: '';
  width: 20rpx;
  height: 20rpx;
  border-right: 3rpx solid #999999;
  border-bottom: 3rpx solid #999999;
  transform: rotate(45deg);
  transition: all 0.3s ease;
  margin-right: 20rpx;
}

.picker:hover .picker-content::before {
  border-color: #667eea;
}

.placeholder {
  color: #999999;
  font-style: italic;
}

@keyframes shake {
  0%, 100% {
    transform: translateX(0);
  }
  25% {
    transform: translateX(-10rpx);
  }
  75% {
    transform: translateX(10rpx);
  }
}

/* 图片上传样式 */
.upload-section {
  margin-top: 16rpx;
}

.uploaded-images {
  display: flex;
  flex-wrap: wrap;
  gap: 24rpx;
  margin-bottom: 16rpx;
}

.image-item {
  position: relative;
  width: 200rpx;
  height: 200rpx;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
  animation: scaleIn 0.3s ease forwards;
}

@keyframes scaleIn {
  from {
    opacity: 0;
    transform: scale(0.8);
  }
  to {
    opacity: 1;
    transform: scale(1);
  }
}

.uploaded-image {
  width: 100%;
  height: 100%;
  background-color: #f5f5f5;
}

.delete-btn {
  position: absolute;
  top: 8rpx;
  right: 8rpx;
  width: 48rpx;
  height: 48rpx;
  background: rgba(245, 108, 108, 0.9);
  border-radius: 50%;
  display: flex;
  justify-content: center;
  align-items: center;
  cursor: pointer;
  transition: all 0.3s ease;
  box-shadow: 0 2rpx 8rpx rgba(245, 108, 108, 0.3);
}

.delete-btn:hover {
  background: rgba(245, 108, 108, 1);
  transform: scale(1.1);
  box-shadow: 0 4rpx 16rpx rgba(245, 108, 108, 0.4);
}

.delete-icon {
  color: #ffffff;
  font-size: 40rpx;
  font-weight: 700;
  line-height: 1;
  margin-top: -4rpx;
}

.upload-btn {
  width: 200rpx;
  height: 200rpx;
  border: 3rpx dashed #cccccc;
  border-radius: 16rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  cursor: pointer;
  transition: all 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
  background: rgba(255, 255, 255, 0.5);
}

.upload-btn:hover {
  border-color: #667eea;
  background: rgba(102, 126, 234, 0.08);
  transform: translateY(-4rpx);
  box-shadow: 0 8rpx 24rpx rgba(102, 126, 234, 0.15);
}

.upload-icon {
  font-size: 64rpx;
  color: #999999;
  margin-bottom: 8rpx;
  transition: all 0.3s ease;
}

.upload-btn:hover .upload-icon {
  color: #667eea;
  transform: scale(1.1);
}

.upload-text {
  font-size: 28rpx;
  color: #666666;
  margin-bottom: 4rpx;
  font-weight: 500;
}

.upload-hint {
  font-size: 22rpx;
  color: #999999;
}

/* 提交按钮 */
.submit-btn {
  width: 100%;
  max-width: 600rpx;
  height: 112rpx;
  font-size: 38rpx;
  font-weight: 700;
  border-radius: 28rpx;
  margin: 20rpx 0;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #ffffff;
  box-shadow: 0 20rpx 60rpx rgba(102, 126, 234, 0.45), 0 10rpx 30rpx rgba(102, 126, 234, 0.35), inset 0 2rpx 4rpx rgba(255, 255, 255, 0.2);
  transition: all 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
  position: relative;
  overflow: hidden;
  animation: buttonSlideIn 0.8s cubic-bezier(0.25, 0.46, 0.45, 0.94) forwards;
  opacity: 0;
  animation-delay: 0.4s;
  border: none;
  display: flex;
  justify-content: center;
  align-items: center;
  letter-spacing: 2rpx;
  text-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.1);
}

@keyframes buttonSlideIn {
  from {
    opacity: 0;
    transform: translateY(30rpx) scale(0.95);
  }
  to {
    opacity: 1;
    transform: translateY(0) scale(1);
  }
}

.submit-btn::before {
  content: '';
  position: absolute;
  top: 0;
  left: -100%;
  width: 100%;
  height: 100%;
  background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.3), transparent);
  transition: all 0.6s ease;
  transform: skewX(-20deg);
}

.submit-btn:hover::before {
  left: 100%;
}

.submit-btn[disabled] {
  background: linear-gradient(135deg, #cccccc 0%, #999999 100%);
  color: #ffffff;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.15);
  transform: none;
  cursor: not-allowed;
  text-shadow: none;
}

/* 成功提示模态框 */
.success-modal {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  justify-content: center;
  align-items: center;
  z-index: 1000;
  animation: fadeIn 0.3s ease forwards;
}

.success-content {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 60rpx 40rpx;
  text-align: center;
  box-shadow: 0 20rpx 60rpx rgba(0, 0, 0, 0.3);
  animation: scaleIn 0.3s ease forwards;
  max-width: 80vw;
}

.success-icon {
  width: 120rpx;
  height: 120rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 50%;
  display: flex;
  justify-content: center;
  align-items: center;
  margin: 0 auto 32rpx;
  color: #ffffff;
  font-size: 80rpx;
  font-weight: 700;
  box-shadow: 0 10rpx 30rpx rgba(102, 126, 234, 0.3);
  animation: bounce 0.6s ease forwards;
}

@keyframes bounce {
  0%, 20%, 50%, 80%, 100% {
    transform: translateY(0);
  }
  40% {
    transform: translateY(-20rpx);
  }
  60% {
    transform: translateY(-10rpx);
  }
}

.success-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #333333;
  margin-bottom: 16rpx;
}

.success-btn {
  width: 200rpx;
  height: 80rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #ffffff;
  border: none;
  border-radius: 40rpx;
  font-size: 32rpx;
  font-weight: 600;
  transition: all 0.3s ease;
  box-shadow: 0 8rpx 24rpx rgba(102, 126, 234, 0.3);
}

.success-btn:hover {
  transform: scale(1.05);
  box-shadow: 0 12rpx 36rpx rgba(102, 126, 234, 0.4);
}