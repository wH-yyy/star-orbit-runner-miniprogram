/* pages/submit/submit.wxss */
.container {
  min-height: 100vh;
  background: linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%);
  padding: 40rpx 30rpx;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.form-item {
  width: 100%;
  max-width: 690rpx;
  margin-bottom: 40rpx;
}

.label {
  display: block;
  font-size: 34rpx;
  font-weight: 600;
  color: #444444;
  margin-bottom: 20rpx;
  letter-spacing: 1rpx;
  line-height: 1.5;
}

.schedule-container {
  width: 100%;
  border: 2rpx solid #e0e0e0;
  border-radius: 24rpx;
  box-sizing: border-box;
  font-size: 34rpx;
  background: rgba(255, 255, 255, 0.9);
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  letter-spacing: 1rpx;
  font-weight: 500;
  user-select: none;
  background: linear-gradient(135deg, rgba(255,255,255,0.9) 0%, rgba(245,247,250,0.9) 100%);
  color: #667eea;
  min-height: 140rpx;
  padding: 30rpx 0;
  line-height: 1.5;
}

.academic-term,
.date-range,
.time-range {
  line-height: 1.5;
  width: 100%;
  text-align: center;
}

.academic-term {
  font-size: 30rpx;
  font-weight: 500;
  color: #6976eb;
  line-height: 1.5;
}

.date-range {
  font-size: 32rpx;
  font-weight: 600;
  color: #5a67d8;
  line-height: 1.5;
}

.time-range {
  font-size: 34rpx;
  font-weight: 600;
  color: #5a67d8;
  line-height: 1.5;
}

.picker {
  width: 100%;
  height: 100rpx;
  border: 2rpx solid #e0e0e0;
  border-radius: 24rpx;
  padding: 0 30rpx;
  box-sizing: border-box;
  background: rgba(255, 255, 255, 0.9);
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
  display: flex;
  align-items: center;
}

.picker:hover {
  border-color: #667eea;
  box-shadow: 0 8rpx 24rpx rgba(102, 126, 234, 0.15);
  transform: translateY(-2rpx);
}

.picker-content {
  font-size: 34rpx;
  color: #333333;
  display: flex;
  align-items: center;
  width: 100%;
  line-height: 1.5;
}

.picker-content::before {
  content: '';
  width: 20rpx;
  height: 20rpx;
  border-right: 2rpx solid #999999;
  border-bottom: 2rpx solid #999999;
  transform: rotate(45deg);
  margin-right: 20rpx;
}

.picker:hover .picker-content::before {
  border-color: #667eea;
}

/* 图片上传样式 */
.upload-section {
  margin-top: 20rpx;
}

.uploaded-images {
  display: flex;
  flex-wrap: wrap;
  gap: 30rpx;
}

.image-item {
  position: relative;
  width: 300rpx;
  height: 300rpx;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.12);
}

.uploaded-image {
  width: 100%;
  height: 100%;
  background-color: #f5f5f5;
}

.delete-btn {
  position: absolute;
  top: 10rpx;
  right: 10rpx;
  width: 40rpx;
  height: 40rpx;
  background: rgba(245, 108, 108, 0.9);
  border-radius: 50%;
  display: flex;
  justify-content: center;
  align-items: center;
  cursor: pointer;
  box-shadow: 0 4rpx 12rpx rgba(245, 108, 108, 0.35);
}

.delete-btn:hover {
  background: rgba(245, 108, 108, 1);
  transform: scale(1.1);
  box-shadow: 0 8rpx 20rpx rgba(245, 108, 108, 0.5);
}

.delete-icon {
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 700;
  line-height: 1;
  margin-top: -4rpx;
}

.upload-btn {
  width: 300rpx;
  height: 300rpx;
  border: 4rpx dashed #cccccc;
  border-radius: 20rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  cursor: pointer;
  background: rgba(255, 255, 255, 0.5);
}

.upload-btn:hover {
  border-color: #667eea;
  background: rgba(102, 126, 234, 0.1);
  transform: translateY(-6rpx);
  box-shadow: 0 12rpx 32rpx rgba(102, 126, 234, 0.2);
}

.upload-icon {
  font-size: 60rpx;
  color: #999999;
  margin-bottom: 10rpx;
}

.upload-btn:hover .upload-icon {
  color: #667eea;
  transform: scale(1.1);
}

.upload-text {
  font-size: 28rpx;
  color: #666666;
  margin-bottom: 6rpx;
  font-weight: 500;
  line-height: 1.4;
}

.upload-hint {
  font-size: 24rpx;
  color: #999999;
  line-height: 1.4;
}

.submit-btn {
  width: 100%;
  max-width: 690rpx;
  height: 110rpx;
  font-size: 38rpx;
  font-weight: 700;
  border-radius: 28rpx;
  margin: 30rpx 0;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #ffffff;
  box-shadow: 0 20rpx 60rpx rgba(102, 126, 234, 0.5), 0 12rpx 30rpx rgba(102, 126, 234, 0.4), inset 0 2rpx 6rpx rgba(255, 255, 255, 0.25);
  position: relative;
  overflow: hidden;
  display: flex;
  justify-content: center;
  align-items: center;
  letter-spacing: 2rpx;
}

.submit-btn::before {
  content: '';
  position: absolute;
  top: 0;
  left: -100%;
  width: 100%;
  height: 100%;
  background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.3), transparent);
  transform: skewX(-20deg);
}

.submit-btn:hover::before {
  left: 100%;
}

.submit-btn[disabled] {
  background: linear-gradient(135deg, #cccccc 0%, #999999 100%);
  color: #ffffff;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.15);
  transform: none;
  cursor: not-allowed;
  text-shadow: none;
}