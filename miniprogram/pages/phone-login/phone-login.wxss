/* pages/phone-login/phone-login.wxss */
.container {
  display: flex;
  justify-content: center;
  align-items: center;
  flex-direction: column;
  height: 100vh;
  width: 100vw;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  padding: 0;
  margin: 0;
  box-sizing: border-box;
  position: fixed;
  top: 0;
  left: 0;
  overflow: hidden;
}

/* 背景装饰 */
.container::before {
  content: '';
  position: absolute;
  top: -50%;
  left: -50%;
  width: 200%;
  height: 200%;
  background: radial-gradient(circle, rgba(255,255,255,0.1) 1px, transparent 1px);
  background-size: 50rpx 50rpx;
  animation: float 20s linear infinite;
}

.login-box {
  width: 100%;
  max-width: 700rpx;
  height: auto;
  min-height: 80vh;
  background: rgba(255, 255, 255, 0.98);
  border-radius: 36rpx;
  box-shadow: 
    0 24rpx 80rpx rgba(0, 0, 0, 0.25), 
    0 10rpx 30rpx rgba(0, 0, 0, 0.15),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.8);
  padding: 120rpx 60rpx;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  position: relative;
  z-index: 1;
  backdrop-filter: blur(20rpx);
  animation: slideUp 0.8s cubic-bezier(0.25, 0.46, 0.45, 0.94) forwards;
  border: 2rpx solid rgba(255, 255, 255, 0.3);
  margin: 40rpx;
}

.logo {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 80rpx;
  animation: pulse 1.2s cubic-bezier(0.68, -0.55, 0.265, 1.55) forwards;
  position: relative;
}

.logo image {
  width: 160rpx;
  height: 160rpx;
  border-radius: 80rpx;
  margin-bottom: 32rpx;
  border: 8rpx solid rgba(255, 255, 255, 0.8);
  box-shadow: 0 16rpx 48rpx rgba(0, 0, 0, 0.2), 0 8rpx 24rpx rgba(0, 0, 0, 0.15);
  transition: all 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
  background-color: #ffffff;
}

.logo .title {
  font-size: 48rpx;
  font-weight: 800;
  color: #333333;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  letter-spacing: 4rpx;
  text-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
}

.form {
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 60rpx;
  margin: 0 auto;
}

.welcome-text {
  text-align: center;
  animation: fadeIn 0.8s ease forwards;
}

.welcome-text .main-text {
  display: block;
  font-size: 40rpx;
  font-weight: 700;
  color: #333333;
  margin-bottom: 16rpx;
  letter-spacing: 2rpx;
}

.welcome-text .sub-text {
  display: block;
  font-size: 28rpx;
  color: #666666;
  line-height: 40rpx;
}

.phone-display {
  width: 100%;
  padding: 24rpx;
  background: rgba(102, 126, 234, 0.08);
  border-radius: 20rpx;
  text-align: center;
  animation: fadeIn 0.8s ease 0.2s forwards;
  opacity: 0;
}

.phone-display .label {
  font-size: 28rpx;
  color: #666666;
  margin-right: 12rpx;
}

.phone-display .phone-text {
  font-size: 32rpx;
  font-weight: 600;
  color: #667eea;
}

.phone-login-btn {
  width: 100%;
  height: 120rpx;
  font-size: 38rpx;
  font-weight: 700;
  border-radius: 32rpx;
  margin: 0;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #ffffff;
  box-shadow: 0 24rpx 72rpx rgba(102, 126, 234, 0.5), 0 12rpx 36rpx rgba(102, 126, 234, 0.4), inset 0 2rpx 6rpx rgba(255, 255, 255, 0.25);
  transition: all 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
  position: relative;
  overflow: hidden;
  animation: buttonSlideIn 0.8s cubic-bezier(0.25, 0.46, 0.45, 0.94) forwards;
  opacity: 0;
  animation-delay: 0.4s;
  border: none;
  display: flex;
  justify-content: center;
  align-items: center;
  letter-spacing: 3rpx;
  text-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.1);
}

.phone-login-btn::before {
  content: '';
  position: absolute;
  top: 0;
  left: -100%;
  width: 100%;
  height: 100%;
  background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.35), transparent);
  transition: all 0.5s ease;
  transform: skewX(-20deg);
}

.phone-login-btn:hover::before {
  left: 100%;
}

.phone-login-btn:active {
  transform: scale(0.98);
  box-shadow: 0 16rpx 48rpx rgba(102, 126, 234, 0.4), 0 8rpx 24rpx rgba(102, 126, 234, 0.3), inset 0 2rpx 6rpx rgba(255, 255, 255, 0.2);
}

.phone-login-btn[disabled] {
  background: linear-gradient(135deg, #cccccc 0%, #999999 100%);
  color: #ffffff;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.15);
  transform: none;
  cursor: not-allowed;
  text-shadow: none;
}

.other-login {
  font-size: 28rpx;
  color: #666666;
  text-align: center;
  animation: fadeIn 0.8s ease 0.6s forwards;
  opacity: 0;
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 12rpx;
}

.other-login .link {
  color: #667eea;
  font-weight: 600;
  text-decoration: underline;
  text-decoration-color: #667eea;
  text-decoration-thickness: 2rpx;
  transition: all 0.3s ease;
}

.other-login .link:hover {
  color: #764ba2;
}

.agreement {
  width: 100%;
  animation: fadeIn 1s ease 0.8s forwards;
  opacity: 0;
  position: relative;
  z-index: 1;
  display: flex;
  justify-content: center;
}

.checkbox-item {
  display: flex;
  align-items: center;
  cursor: pointer;
  user-select: none;
  margin: 8rpx 0;
  width: auto;
}

.custom-checkbox-container {
  display: inline-block;
  width: 36rpx;
  height: 36rpx;
  margin-right: 14rpx;
  vertical-align: middle;
  position: relative;
  top: 0;
}

.custom-checkbox {
  width: 36rpx;
  height: 36rpx;
  border: 3rpx solid #e0e0e0;
  border-radius: 8rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
  background-color: #ffffff;
  vertical-align: middle;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.08);
}

.custom-checkbox.checked {
  background-color: #667eea;
  border-color: #667eea;
  box-shadow: 0 4rpx 12rpx rgba(102, 126, 234, 0.3);
  transform: scale(1.05);
}

.checkbox-inner {
  width: 20rpx;
  height: 12rpx;
  border: 2rpx solid #ffffff;
  border-top: none;
  border-right: none;
  transform: rotate(-45deg);
  transition: all 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
  opacity: 0;
  animation: checkboxCheck 0.3s ease forwards;
}

.agreement-text {
  font-size: 28rpx;
  color: #555555;
  line-height: 40rpx;
  white-space: normal;
  overflow: visible;
  text-overflow: clip;
  display: inline-block;
  vertical-align: middle;
  max-width: 600rpx;
  text-align: left;
}

.agreement-link {
  color: #667eea;
  font-weight: 600;
  cursor: pointer;
  text-decoration: underline;
  text-decoration-color: #667eea;
  text-decoration-thickness: 2rpx;
  transition: all 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
  position: relative;
  padding: 3rpx 8rpx;
  border-radius: 8rpx;
  margin: 0 2rpx;
}

.agreement-link:hover {
  color: #764ba2;
  background: rgba(102, 126, 234, 0.15);
  text-decoration: none;
  transform: translateY(-1rpx);
  box-shadow: 0 2rpx 8rpx rgba(102, 126, 234, 0.2);
}

/* 动画效果 */
@keyframes float {
  0% {
    transform: translate(0, 0) rotate(0deg);
  }
  100% {
    transform: translate(50rpx, 50rpx) rotate(360deg);
  }
}

@keyframes slideUp {
  0% {
    opacity: 0;
    transform: translateY(50rpx);
  }
  100% {
    opacity: 1;
    transform: translateY(0);
  }
}

@keyframes pulse {
  0% {
    transform: scale(0.7);
    opacity: 0;
  }
  50% {
    transform: scale(1.15);
    opacity: 0.8;
  }
  100% {
    transform: scale(1);
    opacity: 1;
  }
}

@keyframes buttonSlideIn {
  from {
    opacity: 0;
    transform: translateY(30rpx) scale(0.95);
  }
  to {
    opacity: 1;
    transform: translateY(0) scale(1);
  }
}

@keyframes fadeIn {
  from {
    opacity: 0;
    transform: translateY(20rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

@keyframes checkboxCheck {
  from {
    opacity: 0;
    transform: rotate(-45deg) scale(0.5);
  }
  to {
    opacity: 1;
    transform: rotate(-45deg) scale(1);
  }
}